def gtk_walk_descendant_widgets(w, cb, cb_data):
	stop = cb(w, cb_data)
	if stop:
		return
	if hasattr(w, 'get_children'):
		for child in w.get_children():
			gtk_walk_descendant_widgets(child, cb, cb_data)

class MenuItem(gtk.MenuItem):
	def get_label_widget(self):
		cb_data = {'label-widget': None}
		def cb(widget, cb_data):
			if isinstance(widget, gtk.Label):
				cb_data['label-widget'] = widget
				return True
		gtk_walk_descendant_widgets(self, cb, cb_data)
		return cb_data['label-widget']
		
	def set_markup(self, markup):
