	dlg.set_title("Error" if title is None else title)
	dlg.set_markup(message_markup)
	if details is not None:
		dlg.set_resizable(True)
		carea = dlg.get_content_area()
		carea.pack_start(Scrollable(Label(markup='<tt>'+glib.markup_escape_text(details)+'</tt>')), True, True)
	dlg.get_widget_for_response(gtk.RESPONSE_OK).connect('clicked', lambda btn, dlg: dlg.destroy(), dlg)

	dlg.connect('map-event', lambda *X: PropertyPersistor(dlg, 'error-dialog', [
		( 'geometry', 'configure-event', lambda wdg, evt: [evt.width, evt.height], lambda wdg, value: wdg.resize(*value) ),
		( 'position', 'configure-event', lambda wdg, evt: wdg.get_position()[:],   lambda wdg, value: wdg.move(*value) ),
	]).apply_saved_properties())

	dlg.show_all()
	dlg.run()
	return dlg



def split_command_args(cmd_str):
	return re.split(r'\s+', cmd_str)

def populate_row_context_menu(menu, items, macros):
	# TODO support submenus
	for definition in items:
		icon, label_template, command_template = [field.replace('\\:', ':') for field in re.split(r'(?<!\\):', definition, maxsplit=2)]
		menuitem_label = Template(label_template).render(**macros)
		if menuitem_label != '':
			enabled = True
			if menuitem_label.startswith(' '):
				menuitem_label = menuitem_label[1:]
				enabled = False
			mi = ImageMenuItem(label=menuitem_label, icon=icon)
			mi.set_sensitive(enabled)
			command = Template(command_template).render(**macros)
			mi.set_data('command_args', split_command_args(command))
			mi.connect('activate', on_context_menu_item_activate, menu)
			menu.append(mi)
	menu.show_all()

def gen_row_data(treeview, c_treepath, tv_col):
