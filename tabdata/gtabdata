def parse_options_string(s):
	ret = {}
	for opt in s.split(','):
		if '=' in opt:
			k, v = opt.split('=', 1)
		else:
			k = opt
			v = True
		ret[k] = v
	return ret

def successor_iter(model, predecessor):
	"""return the next "heir" in line of succession metaphorically speaking.
	i.e. the first child of the node if there is any, otherwise its next sibling node,
	otherwise its parent node's next sibling."""
	if model.iter_has_child(predecessor):
		return model.iter_nth_child(predecessor, 0)
	else:
		successor = model.iter_next(predecessor)
		if successor is None:
			while True:
				parent = model.iter_parent(predecessor)
				if parent is None: return None
				uncle = model.iter_next(parent)
				if uncle is not None: return uncle
				predecessor = parent
			return None
		return successor


class TreeModelRow(object):
	"""proxy class for inextensible gtk.TreeModelRow"""
	def __init__(self, treemodelrow, upstream_treemodel):
		self.real_treemodelrow = treemodelrow
		self.upstream_treemodel = upstream_treemodel
	@property
	def path(self):
		return self.real_treemodelrow.path
	@property
	def iter(self):
		return self.real_treemodelrow.iter
	@property
	def model(self):
		return self.real_treemodelrow.model
	def update(self, row_data):
		"row_data can be a dict with column names as keys, or just a list of the new cells."
		for col_ref, col_data in (row_data if isinstance(row_data, dict) else enumerate(row_data)):
			self[col_ref] = col_data
	def __getitem__(self, item):
		item = self.upstream_treemodel.get_column_num(item)
		answer = gtk.TreeModel.get(self.model, self.iter, item)[0]
		return self.upstream_treemodel.convert_cell(item, answer)
	def __setitem__(self, item, value):
		item = self.upstream_treemodel.get_column_num(item)
		self.real_treemodelrow[item] = value
	def __len__(self):
		return self.real_treemodelrow.__len__()
	def as_dict(self):
		return dict([(col_name, self[col_name]) for col_name in self.upstream_treemodel.column_name])
	def __repr__(self):
		return '<%s %s>' % (self.__class__.__name__, self.as_dict())

class TreeModelProxy(object):
	@staticmethod
	def _proxy_foreach(model, treepath, treeiter, _proxy_userdata):
		func = _proxy_userdata['func']
		userdata = _proxy_userdata['userdata']
		derived_model = _proxy_userdata['derived_model']
		return func(derived_model, treepath, treeiter, userdata)

class TreeStore(gtk.TreeStore):
	__gsignals__ = {
		'changed': (gobject.SIGNAL_RUN_FIRST, gobject.TYPE_NONE, ()),
		'set-changed': (gobject.SIGNAL_RUN_FIRST, gobject.TYPE_NONE, ()),
	}
	def __init__(self, *columns):
		self.column_name = []
		self.reader = {}
		self.empty = []
		types = []
		self.input_types = []
		n = 0
		for col_name, col_type in columns:
			self.input_types.append(col_type)
			empty_value = None
			if col_type == unicode:
				col_type = str
				self.reader[n] = self.to_unicode
			if col_type == str:
				empty_value = ''
			elif col_type in [int, float]:
				empty_value = 0
			self.empty.append(empty_value)
			types.append(col_type)
			self.column_name.append(col_name)
			n += 1
		super(TreeStore, self).__init__(*types)
		for event in 'row-changed', 'row-deleted', 'row-inserted':
			self.connect_after(event, self.emit_signal, 'changed')
			self.connect_after(event, self.emit_signal, 'set-changed')
		self.connect_after('rows-reordered', self.emit_signal, 'changed')
	def emit_signal(self, *args):
		signal_name = args[-1]
		self.emit(signal_name)
	@staticmethod
	def to_unicode(s):
		if s is None: return None
		return unicode(s)
	class ColumnNotFoundException(Exception):
		pass
	def get_columns(self):
		return zip(self.column_name, self.input_types)
	def get_column_num(self, col_ref):
		if isinstance(col_ref, int):
			if col_ref < 0 or col_ref >= len(self.column_name):
				raise TreeStore.ColumnNotFoundException(col_ref)
			return col_ref
		try:
			return self.column_name.index(col_ref)
		except ValueError:
			raise TreeStore.ColumnNotFoundException(col_ref)
	def get_column_name(self, col_num):
		try:
			return self.column_name[col_num]
		except (IndexError, TypeError):
			raise TreeStore.ColumnNotFoundException(col_num)
	def get(self, row, *columns):
		if type(row) == tuple:
			row = self.get_iter(row)  # tree iterator path was given
		if len(columns) == 0:
			return tuple()
		columns = list(columns)
		for i, col in enumerate(columns):
			columns[i] = self.get_column_num(col)
		answer = super(TreeStore, self).get(row, *columns)
		answer = list(answer)
		for i, col_num in enumerate(columns):
			answer[i] = self.convert_cell(col_num, answer[i])
		answer = tuple(answer)
		return answer
	def get_value(self, treeiter, column):
		raise NotImplementedError()
	def convert_cell(self, col_num, cell_value):
		if self.reader.has_key(col_num):
			return self.reader[col_num](cell_value)
		return cell_value
	def __getitem__(self, item):
		answer = super(TreeStore, self).__getitem__(item)
		return TreeModelRow(answer, self)
	def _row_dict_to_list(self, row):
		if type(row) == dict:
			cols = row
			row = self.empty[:]
			for col_name, value in cols.iteritems():
				row[self.get_column_num(col_name)] = value
		return row
	def append(self, parent, row):
		return super(TreeStore, self).append(parent, self._row_dict_to_list(row))
	def insert_after(self, parent, sibling, row):
		return super(TreeStore, self).insert_after(parent, sibling, self._row_dict_to_list(row))
	def insert_before(self, parent, sibling, row):
		return super(TreeStore, self).insert_before(parent, sibling, self._row_dict_to_list(row))
	def set(self, treeiter, *itempairs):
		if len(itempairs) == 0: return
		if type(itempairs[0]) == dict:
			cols = itempairs[0]
			itempairs = []
			for col_name, value in cols.iteritems():
				itempairs.extend([self.get_column_num(col_name), value])
		super(TreeStore, self).set(treeiter, *itempairs)
	def get_cells_by_column(self, col_name):
		treeiter = self.get_iter_root()
		while treeiter is not None:
			yield self[treeiter][col_name]
			treeiter = successor_iter(self, treeiter)
	def walk_columns(self, *columns):
		"""yields a sequence of [TreeModelRow, depth, value-1, value-2, ..., value-n] lists
		for depth being the row's level on the tree and value-1 to value-n being the 
		content of cells in the requested columns in each row"""
		treeiter = self.get_iter_root()
		while treeiter is not None:
			row = self[treeiter]
			answer = [row]
			answer.extend(self.get(treeiter, *columns))
			yield answer
			treeiter = successor_iter(self, row.iter)

def floatOrNone(s):
	try:
		return float(s)
	except (ValueError, TypeError):
		return None

class TreeModelFilterSort(gtk.TreeModelSort):
	def __init__(self, basemodel):
		self.base_model = basemodel
		self.filtering_model = self.base_model.filter_new()
		super(TreeModelFilterSort, self).__init__(self.filtering_model)
		for colnum in range(self.get_n_columns()):
			self.set_sort_func(colnum, self.mixdata_sorter, colnum)
	def mixdata_sorter(self, model, iter1, iter2, colnum):
		content1 = model[iter1][colnum]
		content2 = model[iter2][colnum]
		float1 = floatOrNone(content1)
		float2 = floatOrNone(content2)
		# sort words case-insensitively, and keep numbers before words:
		return cmp(*map(lambda x: x.lower() if isinstance(x, basestring) else x, (float1 if float1 is not None else content1, float2 if float2 is not None else content2)))
	def convert_item_to_basemodel_item(self, item):
		if isinstance(item, gtk.TreeIter):
			filtering_model_iter = self.convert_iter_to_child_iter(None, item)
			return self.filtering_model.convert_iter_to_child_iter(None, filtering_model_iter)
		else:
			filtering_model_path = self.convert_path_to_child_path(item)
			return self.filtering_model.convert_path_to_child_path(filtering_model_path)
	def __getitem__(self, item):
		return self.base_model[self.convert_item_to_basemodel_item(item)]
	def foreach(self, func, userdata):
		_proxy_userdata = {'func': func, 'userdata': userdata, 'derived_model': self}
		super(TreeModelFilterSort, self).foreach(TreeModelProxy._proxy_foreach, _proxy_userdata)
	def get(self, row, *columns):
		raise NotImplementedError()
	def get_value(self, treeiter, column):
		raise NotImplementedError()
	def get_sort_column_name(self):
		col_num, sort_order = self.get_sort_column_id()
		if col_num is not None and col_num >= 0:
			return self.base_model.get_column_name(col_num)
		return None
	def set_sort_column_by_name(self, col_name, sort_order):
		col_num = self.base_model.get_column_num(col_name)
		self.set_sort_column_id(col_num, sort_order)
	# proxy methods:
	def __getattribute__(self, attrname):
		if attrname in ['get_column_num', 'get_column_name', 'get_columns', 'append', 'clear']:
			return object.__getattribute__(self.base_model, attrname)
		elif attrname in ['set_visible_func', 'refilter']:
			return object.__getattribute__(self.filtering_model, attrname)
		else:
			return object.__getattribute__(self, attrname)

def glib_callback_once(func, *args):
	func(*args)
	return False

class TreeView(gtk.TreeView):
	__gsignals__ = {
		'menu-popup': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT, gobject.TYPE_PYOBJECT, gobject.TYPE_PYOBJECT, gobject.TYPE_PYOBJECT, gobject.TYPE_PYOBJECT)),
		'header-menu-popup': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT, gobject.TYPE_PYOBJECT)),
		'column-added': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'column-width-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT, int)),
		'sort-by-column-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'column-sort-order-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'column-visibility-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'selection-change': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
	}
	def __init__(self, base_model):
		super(TreeView, self).__init__(None)
		self.set_model(base_model)
		self._previous_widths = {}
		self._previous_previous_widths = {}
		self._stored_column_width = {}
		self.set_reorderable(True)
		self.set_headers_clickable(True)
		self.set_rubber_banding(True)
		self.get_selection().set_mode(gtk.SELECTION_MULTIPLE)
		self.get_selection().connect('changed', self._on_selection_changed)
		self.connect('button-press-event', self._on_button_click)
		self.connect('realize', self._on_realize)
		self.connect('columns-changed', self._on_columns_changed)
		self.connect('key-release-event', self._on_key_release)
		self.connect('header-menu-popup', self._on_header_menu_popup)
		self.connect_after('expose-event', self._on_expose)

	def _on_expose(self, tv, event):
		self._highlight_focused_cell(event)
		return False
	
	def _highlight_focused_cell(self, event):
		treepath, column = self.get_cursor()
		if treepath is None or column is None:
			return
		rect = self.get_cell_area(treepath, column)
		binwindow = self.get_bin_window()
		if event.window != binwindow:
			return
		style = self.get_style()
		color = style.fg[gtk.STATE_ACTIVE]
		cr = binwindow.cairo_create()
		cr.rectangle(event.area.x, event.area.y, event.area.width, event.area.height)
		cr.clip()
		cr.rectangle(rect.x, rect.y, rect.width, rect.height)
		cr.set_source_rgba(color.red / 65535.0, color.green / 65535.0, color.blue / 65535.0, 1.0)
		cr.set_line_width(1)
		cr.stroke()

	def set_model(self, base_model):
		self.base_model = base_model
		if base_model is not None:
			self.filtersort_model = TreeModelFilterSort(base_model)
			super(TreeView, self).set_model(self.filtersort_model)
			self.set_filter_function(self.default_filtering_cb)
			
			self.filtersort_model.connect('sort-column-changed', self._on_model_sort_column_changed)
		else:
			self.filtersort_model = None
			super(TreeView, self).set_model(base_model)
	
	def set_filter_function(self, func, user_data=None):
		self.filtersort_model.set_visible_func(func, user_data)
	
	def default_filtering_cb(self, model, treeiter, cb_data):
		all_column_filter_match = True
		for col in self.get_columns():
			if col.filter_regex_pattern is not None:
				cell_content = model[treeiter][col.name]
				if cell_content is not None:
					if regex.search(col.filter_regex_pattern, cell_content) is None:
						all_column_filter_match = False
						break
		return all_column_filter_match
	
	def _on_key_release(self, widget, event):
		if event.keyval == gtk.gdk.keyval_from_name('space'):
			iterpath, tv_col = self.get_cursor()
			tv_col.cell_renderers[0].on_start_editing(event, widget, ','.join(map(str, iterpath)), self.get_background_area(iterpath, tv_col), self.get_cell_area(iterpath, tv_col), 0)

	def _on_button_click(self, widget, event):
		if event.button == MOUSE_BUTTON_RIGHT:
			x, y = int(event.x), int(event.y)
			event_target_info = self.get_path_at_pos(x, y)
			if event_target_info is not None:
				treepath, tv_col, cell_x, cell_y = event_target_info
			else:
				treepath, tv_col, cell_x, cell_y = None, None, None, None
			if treepath is not None:
				self.get_selection().select_path(treepath)
			popup_menu = gtk.Menu()
			if not self.emit('menu-popup', popup_menu, treepath, tv_col, cell_x, cell_y):
				# event is not handled by any handlers, so do it ourself
				if popup_menu.get_children():
					popup_menu.show_all()
					popup_menu.popup(None, None, None, event.button, event.time)
			return True

	def _on_realize(self, widget):
		for tvc in self.get_columns():
			self._column_setup_events(tvc)

	def _on_columns_changed(self, widget):
		# clear 'layoutstash', it is needed for CellRendererTextOverflow
		self.set_data('layoutstash', {})

	def set_columns(self, columns):
		for col in self.get_columns(): self.remove_column(col)
		return self.add_columns(columns)
	
	def add_columns(self, columns):
		for col_name, col_title, col_attr, col_num in columns:
			tvc = TreeViewColumn()
			tvc.set_name(col_name)
			tvc.title = col_title
			tvc.set_sort_indicator(True)
			tvc.set_sort_column_id(col_num)
			tvc.set_resizable(True)
			tvc.set_sizing(gtk.TREE_VIEW_COLUMN_FIXED)
			tvc.set_reorderable(True)
			
			cr_txt = CellRendererTextOverflow()
			cr_txt.set_data('treeviewcolumn', tvc)
			tvc.pack_start(cr_txt, expand=True)
			tvc.add_attribute(cr_txt, col_attr, col_num)
			
			tvc.set_data('original-position', len(self.get_columns()))
			self.append_column(tvc)

	def _on_column_width_change(self, col, gparam):
		w = col.get_width()
		if w != self._stored_column_width.get(col.name):
			self.emit('column-width-changed', col, w)
		self._stored_column_width[col.name] = w

	def append_column(self, tvc):
		super(TreeView, self).append_column(tvc)
		self._column_setup_events(tvc)
		self.emit('column-added', tvc)

	def _column_setup_events(self, tvc):
		if hasattr(tvc, 'setup_events'):
			tvc.setup_events()
			if not tvc.get_data('treeview-connect-done'):
				tvc.connect('button-press-event', self._on_column_click)
				tvc.set_data('treeview-connect-done', True)
		tvc.connect('notify::width', self._on_column_width_change)
		tvc.connect('notify::visible', self._on_column_visibility_changed)
		tvc.connect('notify::sort-order', self._on_column_sort_order_changed)
		tvc.connect('filter-expression-changed', lambda tvc, fexpr: self.filtersort_model.refilter())

	def _on_column_click(self, col_widget, event):
		if event.button == MOUSE_BUTTON_RIGHT:
			popup_menu = gtk.Menu()
			if not self.emit('header-menu-popup', popup_menu, col_widget):
				popup_menu.show_all()
				popup_menu.popup(None, None, None, event.button, event.time)
			return True
		elif event.button == MOUSE_BUTTON_LEFT:
			self.set_search_column_by_name(col_widget.name)

	def set_search_column_by_name(self, colname):
		model_col_num = self.get_model().get_column_num(colname)
		self.set_search_column(model_col_num)

	def set_sortby_column_by_name(self, colname):
		tvc_curr_sort_order = self.get_column_by_name(colname).get_sort_order()
		self.get_model().set_sort_column_by_name(colname, tvc_curr_sort_order)
		self.set_search_column_by_name(colname)

	def _on_model_sort_column_changed(self, model):
		col_name = model.get_sort_column_name()
		if col_name is not None:
			col = self.get_column_by_name(col_name)
		else:
			col = None
		self.emit('sort-by-column-changed', col)
		self.emit('column-sort-order-changed', col)

	def _on_column_sort_order_changed(self, tvc, gparam):
		self.emit('column-sort-order-changed', tvc)

	def get_sortby_column(self):
		return self.get_column_by_name( self.get_model().get_sort_column_name() )

	def _on_column_visibility_changed(self, tvc, gparam):
		self.emit('column-visibility-changed', tvc)
	
	class ColumnNotFoundException(Exception):
		pass

	def get_column_by_name(self, colname):
		for col in self.get_columns():
			if col.name == colname:
				return col
		raise TreeView.ColumnNotFoundException(colname)
	
	def get_column_number_by_name(self, colname):
		for num, col in enumerate(self.get_columns()):
			if col.name == colname:
				return num
		raise TreeView.ColumnNotFoundException(colname)
	
	def columns_autosize(self, cols=None):
		if cols is None:
			cols = self.get_columns()
		for tvc in cols:
			if tvc.name in self._previous_widths:
				self._previous_previous_widths[tvc.name] = self._previous_widths[tvc.name]
			self._previous_widths[tvc.name] = tvc.get_width()
			tvc.disable_ellipsize()
			tvc.clear_width_requirement()
		glib.idle_add(glib_callback_once, self._columns_autosize_set_autosize, cols, priority=glib.PRIORITY_DEFAULT_IDLE)
	def _columns_autosize_set_autosize(self, cols):
		for tvc in cols:
			tvc.reset_fixed_width()
			tvc.set_sizing(gtk.TREE_VIEW_COLUMN_AUTOSIZE)
		#gtk.TreeView.columns_autosize(self)
		glib.idle_add(glib_callback_once, self._columns_autosize_restore_resizable, cols, priority=glib.PRIORITY_DEFAULT_IDLE)
	def _columns_autosize_restore_resizable(self, cols):
		for tvc in cols:
			width = tvc.get_width()
			tvc.set_sizing(gtk.TREE_VIEW_COLUMN_FIXED)
			if width > 1:
				tvc.set_fixed_width(width)
				if width == self._previous_widths[tvc.name]:
					self._previous_widths[tvc.name] = self._previous_previous_widths.get(tvc.name)
			tvc.set_resizable(True)
			tvc.enable_ellipsize()
	def restore_previous_widths(self, cols=None):
		if cols is None:
			cols = self.get_columns()
		for tvc in cols:
			if self._previous_widths.get(tvc.name) is not None:
				tvc.set_fixed_width(self._previous_widths[tvc.name])

	def _on_header_menu_popup(self, tv, popup_menu, tv_col):
		mi = ImageMenuItem(label=("don't filter" if tv_col.is_filtering_open else "filter (regexp) …"), icon=gtk.STOCK_FIND)
		mi.connect('activate', lambda mi: tv_col.toggle_filtering())
		popup_menu.append(mi)

		if tv_col.get_text_alignment() == gtk.JUSTIFY_RIGHT:
			mi = ImageMenuItem(label="align to left", icon=gtk.STOCK_JUSTIFY_LEFT)
			mi.connect('activate', lambda mi, col: col.set_text_alignment(gtk.JUSTIFY_LEFT), tv_col)
		else:
			mi = ImageMenuItem(label="align to right", icon=gtk.STOCK_JUSTIFY_RIGHT)
			mi.connect('activate', lambda mi, col: col.set_text_alignment(gtk.JUSTIFY_RIGHT), tv_col)
		popup_menu.append(mi)

		if tv_col.get_font_desc().get_family() == 'monospace':
			mi = ImageMenuItem(label="normal font", icon=gtk.STOCK_SELECT_FONT)
			mi.connect('activate', lambda mi, col: col.set_font_desc(None), tv_col)
		else:
			mi = ImageMenuItem(label="monospace font", icon=gtk.STOCK_SELECT_FONT)
			mi.connect('activate', lambda mi, col: col.set_font_desc('monospace'), tv_col)
		popup_menu.append(mi)

		mi = ImageMenuItem(label="auto width")
		mi.connect('activate', lambda mi, tv_col: self.columns_autosize([tv_col]), tv_col)
		popup_menu.append(mi)
		mi = ImageMenuItem(label="undo auto width", icon=gtk.STOCK_UNDO)
		mi.connect('activate', lambda mi, tv_col: self.restore_previous_widths([tv_col]), tv_col)
		mi.set_sensitive(tv_col.name in self._previous_widths)
		popup_menu.append(mi)

		popup_menu.append(gtk.SeparatorMenuItem())
		columns_submenu = SubmenuMenuItem(label='columns')
		popup_menu.append(columns_submenu)
		for col in self.get_columns():
			markup = glib.markup_escape_text(col.title)
			if tv_col.name == col.name:
				markup = '<b>' + markup + '</b>'
			mi = CheckMenuItem(markup=markup)
			mi.set_active(col.get_visible())
			mi.connect('activate', lambda mi, col: col.set_visible(not col.get_visible()), col)
			columns_submenu.append(mi)
		mi = MenuItem(label="auto width all columns")
		mi.connect('activate', lambda mi: self.columns_autosize())
		popup_menu.append(mi)
		mi = ImageMenuItem(label="undo auto width all", icon=gtk.STOCK_UNDO)
		mi.connect('activate', lambda mi: self.restore_previous_widths())
		popup_menu.append(mi)
		mi = ImageMenuItem(label="reset columns order", icon=gtk.STOCK_REVERT_TO_SAVED)
		mi.connect('activate', lambda mi: self.reset_columns_original_position())
		popup_menu.append(mi)

	def reset_columns_original_position(self):
		preceding_col = None
		for pos in range(len(self.get_columns())):
			for col in self.get_columns():
				if col.get_data('original-position') == pos:
					self.move_column_after(col, preceding_col)
					preceding_col = col
					break

	def _on_selection_changed(self, selection):
		model, paths = selection.get_selected_rows()[:]
		self.emit('selection-change', [model[treepath] for treepath in paths])

class TreeViewColumn(gtk.TreeViewColumn):
	__gsignals__ = {
		'button-press-event': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'filter-expression-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (str,)),
		'font-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (str,)),
		'alignment-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (str,)),
	}
	def __init__(self, **opt):
		super(TreeViewColumn, self).__init__(**opt)
		header_widget = gtk.VBox()
		self.header_label = Label('')
		header_widget.pack_start(self.header_label, expand=False, fill=False)
		header_widget.show_all()
		self.set_widget(header_widget)
		
		self.attribute_mapping = {}
		self.cellrenderers_left = []
		self.cellrenderers_right = []

		self._saved_filter_expr = None
		self.filter_regex_pattern = None
		self.filter_entrybox = gtk.Entry()
		self.filter_entrybox.set_width_chars(1)  # minimal width so its final width is controlled by the column width
		self.filter_entrybox.connect('changed', lambda editable: self.filter_expression_changed())
		self.filter_entrybox.connect('notify::visible', lambda wdg, gparam: self.filter_expression_changed())

	def add_attribute(self, cellrenderer, attrname, col_num):
		super(TreeViewColumn, self).add_attribute(cellrenderer, attrname, col_num)
		if cellrenderer not in self.attribute_mapping: self.attribute_mapping[cellrenderer] = {}
		self.attribute_mapping[cellrenderer][attrname] = col_num
	def pack_start(self, cellrenderer, expand=True):
		super(TreeViewColumn, self).pack_start(cellrenderer, expand)
		self.cellrenderers_left.append(cellrenderer)
	def pack_end(self, cellrenderer, expand=True):
		super(TreeViewColumn, self).pack_end(cellrenderer, expand)
		self.cellrenderers_right.insert(0, cellrenderer)
	def get_cell_renderers(self):
		return self.cellrenderers_left + self.cellrenderers_right
	@property
	def cell_renderers(self):
		return self.get_cell_renderers()
	
	def reset_fixed_width(self):
		self.set_fixed_width(1)
	def clear_width_requirement(self):
		if self.get_visible():
			self.set_visible(False)
			self.set_visible(True)

	def open_filtering(self):
		self.filter_entrybox.show()
		self.filter_entrybox.grab_focus()
	def close_filtering(self):
		self.filter_entrybox.hide()
	def toggle_filtering(self):
		if self.is_filtering_open:
			self.close_filtering()
		else:
			self.open_filtering()
	@property
	def is_filtering_open(self):
		return self.filter_entrybox.get_visible()
	@property
	def filter_expr(self):
		if self.is_filtering_open:
			return self.filter_entrybox.get_text()
		return None
	@filter_expr.setter
	def filter_expr(self, s):
		self.set_filter_expr(s)
	def set_filter_expr(self, s):
		if s is None:
			self.close_filtering()
		else:
			self.open_filtering()
			self.filter_entrybox.set_text(s)
	def filter_expression_changed(self):
		old = self._saved_filter_expr
		new = self.filter_expr
		if old != new:
			filter_regex_pattern = None
			if new is not None:
				try:
					filter_regex_pattern = regex.compile(new, flags = regex.IGNORECASE | regex.VERSION1)
				except Exception as e:
					self.filter_entrybox.modify_base(gtk.STATE_NORMAL, gtk.gdk.Color('#FFA4A4'))
					self.filter_entrybox.set_tooltip_text(str(e))
				else:
					self.filter_entrybox.modify_base(gtk.STATE_NORMAL, None)
					self.filter_entrybox.set_tooltip_text(None)
			self.filter_regex_pattern = filter_regex_pattern
			self.emit('filter-expression-changed', new)
			self._saved_filter_expr = new

	@property
	def name(self):
		return self.get_name()
	@property
	def title(self):
		return self.header_label.get_text()
	@title.setter
	def title(self, title):
		self.header_label.set_text(title)
	def __repr__(self):
		return '<%s name="%s">' % (self.__class__.__name__, self.name)
	def setup_events(self, *X):
		# this method should be called when the TreeView is realized.
		if not self.get_data('setup-events-done'):
			# find the button representing the treeview column header:
			potential_header_button = self.get_widget()
			while not isinstance(potential_header_button, gtk.Button):
				potential_header_button = potential_header_button.get_parent()
			if potential_header_button is not None:
				# propagate click events upward:
				potential_header_button.connect('button-press-event', lambda widget, event: self.emit('button-press-event', event))
				# insert a VBox into the widget hierarchy under the header button:
				hbox = potential_header_button.get_child()
				potential_header_button.remove(hbox)
				vbox = gtk.VBox()
				potential_header_button.add(vbox)
				vbox.pack_start(hbox, expand=False, fill=False)
				vbox.pack_start(self.filter_entrybox, expand=True, fill=False)
				vbox.show_all()
				self.filter_entrybox.hide()
				# lower down the implicite TreeViewColumn header button, so filter_entrybox gets events:
				potential_header_button.get_event_window().lower()
			
			# align column header label to the top vertically:
			potential_alignment_widget = self.get_widget()
			while not isinstance(potential_alignment_widget, gtk.Alignment):
				potential_alignment_widget = potential_alignment_widget.get_parent()
			if potential_alignment_widget is not None:
				potential_alignment_widget.props.yalign = 0.0
				potential_alignment_widget.props.yscale = 0.0

			self.set_data('setup-events-done', True)
	class NotSupportedAlignmentError(Exception):
		pass
	def set_text_alignment(self, alignment):
		if alignment in [gtk.JUSTIFY_RIGHT, pango.ALIGN_RIGHT]:
			self.cell_renderers[0].set_property('xalign', 1.0)
		elif alignment in [gtk.JUSTIFY_LEFT, pango.ALIGN_LEFT]:
			self.cell_renderers[0].set_property('xalign', 0.0)
		else:
			raise TreeViewColumn.NotSupportedAlignmentError(alignment)
		if self.get_ellipsize_enabled():
			self.enable_ellipsize()
		self.emit('alignment-changed', alignment.value_nick)
	def get_text_alignment(self):
		return gtk.JUSTIFY_RIGHT if self.cell_renderers[0].get_property('xalign') >= 1 else gtk.JUSTIFY_LEFT
	def enable_ellipsize(self):
		text_alignment = self.get_text_alignment()
		if text_alignment == gtk.JUSTIFY_RIGHT:
			self.cell_renderers[0].set_property('ellipsize', pango.ELLIPSIZE_START)
		else:
			self.cell_renderers[0].set_property('ellipsize', pango.ELLIPSIZE_END)
	def disable_ellipsize(self):
		self.cell_renderers[0].set_property('ellipsize', pango.ELLIPSIZE_NONE)
	def get_ellipsize_enabled(self):
		return self.cell_renderers[0].get_property('ellipsize') != pango.ELLIPSIZE_NONE
	def set_font_desc(self, font):
		if not isinstance(font, pango.FontDescription): font = pango.FontDescription(font)
		self.cell_renderers[0].set_property('font-desc', font)
		self.emit('font-changed', font.to_string())
	def get_font_desc(self):
		return self.cell_renderers[0].get_property('font-desc')

class CellRendererTextOverflow(gtk.GenericCellRenderer):
	"""
	This class implements a CellRenderer which renders (markup) text just like
	CellRendererText, but allows the text content to flow over to adjacent empty cells.
	"""
	__gproperties__ = {
		'text': (gobject.TYPE_STRING, 'Text', 'Text', None, gobject.PARAM_READWRITE),
		'markup': (gobject.TYPE_STRING, 'Markup', 'Markup', None, gobject.PARAM_READWRITE),
		'editable': (gobject.TYPE_BOOLEAN, 'Editable', 'Editable', False, gobject.PARAM_READWRITE),
		'xalign': (gobject.TYPE_FLOAT, 'Horizontal Alignment', 'Horizontal Alignment', 0.0, 1.0, 0.0, gobject.PARAM_READWRITE),
	}
	def __init__(self):
		super(CellRendererTextOverflow, self).__init__()
		self.__gobject_init__()
		self.cr_txt = gtk.CellRendererText()
		self.the_props = {'markup': None, 'xalign': 0.0}
		self.set_property('ellipsize', pango.ELLIPSIZE_END)
	def connect(self, *args):
		self.cr_txt.connect(*args)
	class TextAlignmentNotSupported(Exception):
		pass
	def do_set_property(self, pspec, val):
		self.cr_txt.set_property(pspec.name, val)
		if pspec.name in self.the_props:
			self.the_props[pspec.name] = val
	def do_get_property(self, pspec):
		if pspec.name in self.the_props:
			# CellRendererText can not read 'markup', 'xalign' (potentially other) properties back, so we do
			return self.get_property(pspec.name)
		return self.cr_txt.get_property(pspec.name)
	def set_property(self, prop, val):
		if prop in self.the_props:
			self.the_props[prop] = val
		return self.cr_txt.set_property(prop, val)
	def get_property(self, prop):
		if prop == 'pango-alignment':
			if self.the_props['xalign'] == 0.5: raise CellRendererTextOverflow.TextAlignmentNotSupported(pango.ALIGN_CENTER)
			elif self.the_props['xalign'] > 0.5: return pango.ALIGN_RIGHT
			else: return pango.ALIGN_LEFT
		if prop in self.the_props:
			return self.the_props[prop]
		return self.cr_txt.get_property(prop)
	def on_get_size(self, widget, cell_area):
		x, y, w, h = self.cr_txt.get_size(widget, cell_area)
		return x, y, w, h
	
	def draw_layout(self, window, widget, cell_area, layout, flags):
		base_grctx = widget.style.black_gc
		if (flags & gtk.CELL_RENDERER_SELECTED) != 0: base_grctx = widget.style.white_gc
		window.draw_layout(base_grctx, cell_area.x, cell_area.y, layout)
		return False
	def on_render(self, window, widget, background_area, cell_area, expose_area, flags):
		"""Find out how much empty area we have horizontally
		by sum the width of empty cells on right of the current cell.
		Then render the (possibly markup) text on a pango Layout.
		Save the data neccessary to draw the Layout into 'layoutstash' for each cells 
		which are found empty. Cells are identified by TreeModel path and TreeViewColumn name.
		When an actual empty cell is encountered, then recall the saved Layout (if any) and
		redraw it. It assumes that the controller routine requests us to
		render the cells from left to right in sequence and row-by-row."""

		markup = self.get_property('markup')
		text = self.get_property('text')
		align_left = self.get_property('pango-alignment') == pango.ALIGN_LEFT
		align_right = self.get_property('pango-alignment') == pango.ALIGN_RIGHT
		
		tvc = self.get_data('treeviewcolumn')
		tv = tvc.get_tree_view()
		model = tv.get_model()
		cellinfo = tv.get_path_at_pos(cell_area.x, cell_area.y)
		if cellinfo is None:
			cellinfo = tv.get_path_at_pos(cell_area.x + cell_area.width, cell_area.y + cell_area.height)
		if cellinfo is None:
			return
		treepath = cellinfo[0]
		
		if tv.get_data('last-drawn-row-treepath') != treepath or tv.get_data('layoutstash') is None:
			tv.set_data('layoutstash', {})
		tv.set_data('last-drawn-row-treepath', treepath)
		layoutstash = tv.get_data('layoutstash')
		
		def get_adjacent_columns():
			cols = tv.get_columns()
			col_idx = cols.index(tvc)
			adjacent_cols_names = []
			adjacent_cols_width = 0
			col_idx_incr = 1 if align_left else -1
			while True:
				col_idx += col_idx_incr
				if col_idx < 0 or col_idx >= len(cols): break
				column_text = model[treepath][cols[col_idx].name]
				if column_text is None or column_text == '':
					adjacent_cols_width += cols[col_idx].get_width()
					adjacent_cols_names.append(cols[col_idx].name)
				else:
					break
			return adjacent_cols_names, adjacent_cols_width
		adjacent_cols_names, adjacent_cols_width = get_adjacent_columns()
		overflow_width = cell_area.width + adjacent_cols_width

		if overflow_width != cell_area.width:
			possibly_overflow = True
		else:
			possibly_overflow = False
		if possibly_overflow:
			context = widget.get_pango_context()
			layout = pango.Layout(context)
			if markup:
				layout.set_markup(markup)
			elif text:
				layout.set_text(text)
			if markup or text:
				layout.set_width(overflow_width * pango.SCALE)
				layout.set_wrap(pango.WRAP_CHAR)
				layout.set_alignment(self.get_property('pango-alignment'))
				layout.set_ellipsize(pango.ELLIPSIZE_END if align_left else pango.ELLIPSIZE_START)
				# TODO disable underlaying self.cr_txt ellipsize row-by-row if it's overdrawn
				layout.set_font_description(self.get_property('font-desc'))

				xpad, ypad = self.cr_txt.get_padding()
				draw_area = cell_area.copy()
				draw_area.x += xpad
				draw_area.y += ypad
				if align_right:
					draw_area.x -= adjacent_cols_width + 2*xpad
					draw_area.width = overflow_width
					# draw on the left-hand side empty cells immediately, no need to stash the layout for later use:
					self.draw_layout(window, widget, draw_area, layout, flags)
					return True
				else:
					if not layoutstash.has_key(treepath):
						layoutstash[treepath] = {}
					for colname in layoutstash[treepath].keys():
						if layoutstash[treepath][colname].has_key(tvc.name):
							del layoutstash[treepath][colname][tvc.name]
					for colname in adjacent_cols_names:
						if not layoutstash[treepath].has_key(colname):
							layoutstash[treepath][colname] = {}
						layoutstash[treepath][colname][tvc.name] = (window, widget, draw_area, layout, flags)
		else:
			# this cell's text does not flow over, so delete earlier layouts, if any
			for colname in layoutstash.get(treepath, {}).keys():
				if layoutstash[treepath][colname].has_key(tvc.name):
					del layoutstash[treepath][colname][tvc.name]
		layout_overflowcells = layoutstash.get(treepath, {}).get(tvc.name, {})
		if not markup and not text:
			# current cell is empty, but redraw those cells which flow over to this one
			for layout_args in layout_overflowcells.values():
				self.draw_layout(*layout_args)
		else:
			if layout_overflowcells:
				# current cell is not empty so delete those layouts which would be drawn on it, if any
				del layoutstash[treepath][tvc.name]
			self.cr_txt.render(window, widget, background_area, cell_area, expose_area, flags)
		
		return True
	
	def on_activate(self, event, widget, path, background_area, cell_area, flags):
		return self.cr_txt.activate(event, widget, path, background_area, cell_area, flags)
	def on_start_editing(self, event, widget, path, background_area, cell_area, flags):
		ce = self.cr_txt.start_editing(event, widget, path, background_area, cell_area, flags)
		w = gtk.Window(gtk.WINDOW_TOPLEVEL)
		w.set_keep_above(True)
		w.set_modal(True)
		w.set_skip_taskbar_hint(True)
		w.set_transient_for(widget.get_ancestor(gtk.Window))
		w.set_decorated(False)
		frame = gtk.Frame(label = "Enter new value")
		frame.set_border_width(24)
		frame.set_shadow_type(gtk.SHADOW_IN)
		frame_inner = gtk.Frame()
		frame_inner.set_border_width(16)
		w.add(frame)
		frame.add(frame_inner)
		frame_inner.add(ce)
		w.show_all()
		add_key_binding(w, 'Escape', lambda *X: w.destroy())
		w.connect('destroy', lambda *X: w.destroy())
		ce.connect('remove-widget', lambda *X: w.destroy())
		ce.start_editing(event)

