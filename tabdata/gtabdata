			'row': treeview.get_model()[c_treepath].as_dict(),
		}
		command = Template(command_template).render(**macros)
		run_system_command_async(split_command_args(command), gen_row_data(treeview, c_treepath, tv_col))

def run_system_command_async(command_with_args, input_object):
	Thread(target=run_system_command, args=(command_with_args, json.dumps(input_object)), daemon=True).start()

def run_system_command(command_with_args, input_text):
	try:
		proc = spawn_subprocess(command_with_args, shell=False, stdin=subprocess.PIPE, stderr=subprocess.PIPE, close_fds=True)
		proc.stdin.write(input_text)
		proc.stdin.close()
		wait_subprocess(proc)
	except SubprocessError as err:
		with GtkThreadContext():
			ErrorMessage("Command failed with %s: <tt>%s</tt>\nDetails:" % (err.type, err.code), title="gTabData: execution error", details=err.details)


def tabdata(rawline, n_fields=0):
	def unescape_td_sequence(s):
		"""only meant for backslash-t, backslash-n, backslash-r, backslash-e and double-blackslash inputs."""
		if s == '\\e': return '\x1B'
		else: return eval('"'+s+'"')
	cells = [re.sub(r'\\[tnre\\]', lambda match: unescape_td_sequence(match.group(0)), cell) for cell in rawline.rstrip('\n').split('\t', n_fields-1)]
	if n_fields > 0:
		cells = cells + [''] * (n_fields-len(cells))
	return cells


def merge_ordering(old_items, new_items):
	result = []
	for patchline in difflib.ndiff(old_items, new_items):
		op, item = patchline[0], patchline[2:]
		if op in ('+', ' ') or (op == '-' and item not in new_items):
			result.append(item)
	return result

def treemodel_find_row(model, treepath, treeiter, cb_data):
	if model[treepath][cb_data['column-name']] == cb_data['value']:
		cb_data['treepath'] = treepath
		return True

def get_path_by_cell(model, search_column, search_content):
	search_data = {'column-name': search_column, 'value': search_content, 'treepath': None}
	model.foreach(treemodel_find_row, search_data)
	return search_data['treepath']



def parse_cli_args():
	parser = argparse.ArgumentParser(description='gTabData - GTK Tabular Data viewer', formatter_class=argparse.RawDescriptionHelpFormatter)
	parser.add_argument('--title', type=str, default='gTabData', help='Window title text')
	parser.add_argument('--appname', type=str, default='gtabdata', help='Custom application name to operate as')
	parser.add_argument('--icon', type=str, default='text-spreadsheet', help='Window icon file or symbolic name')
	data_group = parser.add_mutually_exclusive_group()
	data_group.add_argument('--data-command', type=str, metavar='COMMAND', help='The command which produces the tabular data to be shown')
	data_group.add_argument('--data-script', type=str, metavar='SCRIPT', help='Shell command(s) to produce tabular data')
	data_group.add_argument('--db-query', type=str, help='Database query to load data from')
	parser.add_argument('--db-connection', type=str, help='Database connection string, for supported DSN see "sqlalchemy" python module.')
	key_group = parser.add_mutually_exclusive_group()
	key_group.add_argument('--key-field', type=str, default=None, metavar='COLUMN')
	key_group.add_argument('--auto-key-field', action='store_true', default=False, help='Default key field is the first column in the input data.')
	parser.add_argument('--activate-command', type=str, metavar='COMMAND', help='System command to run when double clicked on a row.')
	parser.add_argument('--context-menu', action='append', default=[], type=str, metavar='ICON:LABEL:COMMAND', help='Menu item definitions for rows context menu.')
	parser.add_argument('--auto-refresh-interval', type=float, metavar='SEC')
	parser.add_argument('--inotify-refresh', type=str, metavar='FILE', help='')  # TODO
	parser.epilog = '''
COMMAND
	The COMMAND option parameter is a jinja2 template, after rendered, split by whitespaces into command and arguments, no quoting or escaping is supported.
	Then the command is run as a system command, not in shell.
	For available jinja2 variables, see LABEL paragraph below.
	A JSON object is passed to the command's STDIN with these keys:
	- row: an object itself containing all fields (as object keys) and cells (as values) of the activated row
	- col: column's name which the context menu is opened in
	- selected_rows: list of all the selected rows' fields
ICON is one of these:
	- image file path
	- Gtk stock icon constant, starting with "STOCK_"
	- icon name as defined in the current Gtk icon theme
	- basename of an image file in the common system icon directories
LABEL is a jinja2 template rendered to the menu item label, supporting these variables:
	- n_selected: number of selected rows
	- cell: the cell's text content on which the context menu is opened
	- column: the column name in which the context menu is opened
	- row: a dict holding the focused/activated row's fields
	Literal ":" should be escaped by backslash.
	If the rendered LABEL is empty string, the menu item won't be shown.
	If the rendered LABEL starts with a space, the menu item is shown disabled.
'''
	return parser.parse_args()


