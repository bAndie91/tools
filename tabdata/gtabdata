		dlg.set_resizable(True)
		carea = dlg.get_content_area()
		carea.pack_start(Scrollable(Label(markup='<tt>'+glib.markup_escape_text(details)+'</tt>')), True, True)
	dlg.get_widget_for_response(gtk.RESPONSE_OK).connect('clicked', lambda btn, dlg: dlg.destroy(), dlg)

	dlg.connect('map-event', lambda *X: PropertyPersistor(dlg, 'error-dialog', [
		( 'geometry', 'configure-event', lambda wdg, evt: [evt.width, evt.height], lambda wdg, value: wdg.resize(*value) ),
		( 'position', 'configure-event', lambda wdg, evt: wdg.get_position()[:],   lambda wdg, value: wdg.move(*value) ),
	]).apply_saved_properties())

	dlg.show_all()
	dlg.run()
	return dlg



def split_command_args(cmd_str):
	return re.split(r'\s+', cmd_str)

class MenuHierarchy(object):
	def __init__(self, separator='/', menu_class=gtk.Menu):
		self.separator = separator
		self.menu_class = menu_class
		self.default_submenuitem_class = gtk.MenuItem
		self.root_menu = self.menu_class()
	def get_submenu(self, path):
		menu = self.root_menu
		for label in path:
			menu = self.get_submenu_by_label(menu, label)
			if menu is None:
				return None
		return menu
	def get_submenuitem_by_label(self, parent, label):
		for mi in parent.get_children():
			if mi.get_label() == label and mi.get_submenu() is not None:
				return mi
		return None
	def get_submenu_by_label(self, parent, label):
		mi = self.get_submenuitem_by_label(parent, label)
		if mi is not None:
			return mi.get_submenu()
		return None
	def make_submenu(self, path, parent_menu_item_class=None, parent_menu_item_opt={}):
		if parent_menu_item_class is None:
			parent_menu_item_class = self.default_submenuitem_class
		menu = self.root_menu
		for label in path:
			submenu = self.get_submenu_by_label(menu, label)
			if submenu is None:
				submenu = self.menu_class()
				parent_menu_item_opt['label']=label
				smi = parent_menu_item_class(**parent_menu_item_opt)
				smi.set_submenu(submenu)
				submenu.parent_menu_item = smi
				menu.append(smi)
			menu = submenu
		return menu
	def add_menu_item(self, **opt):
		path = opt['label'].split(self.separator)
		opt['label'] = path[-1]
		path = path[0:-1]
		klass = opt.pop('klass')
		if opt['label'] != '':
			submenu = self.make_submenu(path)
			mi = klass(**opt)
			submenu.append(mi)
			return mi
		else:
			self.make_submenu(path[0:-1])
			submenu = self.make_submenu(path, parent_menu_item_class=klass, parent_menu_item_opt=opt)
			return submenu.parent_menu_item
	def append_to_menu(self, recv_menu):
		for mi in list(self.root_menu.get_children()):
			self.root_menu.remove(mi)
			recv_menu.append(mi)

def populate_row_context_menu(menu, items, macros):
	hierarchy = MenuHierarchy(separator='//')
	for definition in items:
		icon, label_template, menuitem_options, command_template = [field.replace('\\:', ':') for field in re.split(r'(?<!\\):', definition, maxsplit=3)]
		menuitem_options = parse_options_string(menuitem_options)
		menuitem_label = Template(label_template).render(**macros)
		if menuitem_label != '':
			enabled = True
			if menuitem_label.startswith(' '):
				menuitem_label = menuitem_label[1:]
				enabled = False
			mi = hierarchy.add_menu_item(klass=ImageMenuItem, label=menuitem_label, icon=icon)
			mi.set_sensitive(enabled)
			
			commands = []
			if menuitem_options.get('per-each-selected-row'):
				for row in macros['selected_rows']:
					command = Template(command_template).render(row=row, n_selected=macros['n_selected'], column=macros['column'])
					if command != '':
						commands.append(split_command_args(command))
			else:
				command = Template(command_template).render(**macros)
				if command != '':
					commands.append(split_command_args(command))
			mi.set_data('commands', commands)
			mi.connect('activate', on_context_menu_item_activate, menu)
	hierarchy.append_to_menu(menu)
	menu.show_all()

def gen_focus_data(treeview, c_treepath, tv_col):
	row = {} if c_treepath is None else treeview.get_model()[c_treepath].as_dict()
	column = None if tv_col is None else tv_col.name
	selected_rows = [treeview.get_model()[treepath].as_dict() for treepath in treeview.get_selection().get_selected_rows()[1]]
	return {
		'row': row,
		'column': column,
		'cell': row.get(column),
		'selected_rows': selected_rows,
	}

def on_context_menu_item_activate(mi, menu):
	focus_data = menu.get_data('focus-data')
	commands = mi.get_data('commands')
	for command_args in commands:
		run_system_command_async(command_args, focus_data)

def on_context_menu_copy(mi, menu, what):
	focus_data = menu.get_data('focus-data')
	if what == 'cell':
		text = focus_data['row'][focus_data['column']]
	elif what == 'row-as-json':
		text = json.dumps(focus_data['row'])
	elif what == 'selection-as-json':
		text = json.dumps(focus_data['selected_rows'])
	else:
		raise ValueError()
	gtk.Clipboard().set_text(text)

def on_table_row_activated(treeview, c_treepath, tv_col):
	if cliargs.activate_command is not None:
		command_template = cliargs.activate_command
		macros = {
			'row': treeview.get_model()[c_treepath].as_dict(),
		}
		command = Template(command_template).render(**macros)
		run_system_command_async(split_command_args(command), gen_focus_data(treeview, c_treepath, tv_col))

def run_system_command_async(command_with_args, input_object):
	Thread(target=run_system_command, args=(command_with_args, json.dumps(input_object)), daemon=True).start()

def run_system_command(command_with_args, input_text):
	try:
		proc = spawn_subprocess(command_with_args, shell=False, stdin=subprocess.PIPE, stderr=subprocess.PIPE, close_fds=True)
		try:
			proc.stdin.write(input_text)
		except IOError as e:
			traceback.print_exc()
			if e.errno not in [errno.EPIPE]: raise e
		proc.stdin.close()
		wait_subprocess(proc)
	except SubprocessError as err:
		with GtkThreadContext():
			ErrorMessage("Command failed with %s: <tt>%s</tt>\nDetails:" % (err.type, err.code), title="gTabData: execution error", details=err.details)


def tabdata(rawline, n_fields=0):
	def unescape_td_sequence(s):
		"""only meant for backslash-t, backslash-n, backslash-r, backslash-e and double-blackslash inputs."""
		if s == '\\e': return '\x1B'
		else: return eval('"'+s+'"')
	cells = [re.sub(r'\\[tnre\\]', lambda match: unescape_td_sequence(match.group(0)), cell) for cell in rawline.rstrip('\n').split('\t', n_fields-1)]
	if n_fields > 0:
		cells = cells + [''] * (n_fields-len(cells))
	return cells


def merge_ordering(old_items, new_items):
	result = []
	for patchline in difflib.ndiff(old_items, new_items):
		op, item = patchline[0], patchline[2:]
		if op in ('+', ' ') or (op == '-' and item not in new_items):
			result.append(item)
	return result

def treemodel_find_row(model, treepath, treeiter, cb_data):
	if model[treepath][cb_data['column-name']] == cb_data['value']:
		cb_data['treepath'] = treepath
		return True

def get_path_by_cell(model, search_column, search_content):
	search_data = {'column-name': search_column, 'value': search_content, 'treepath': None}
	model.foreach(treemodel_find_row, search_data)
	return search_data['treepath']



def parse_cli_args():
	parser = argparse.ArgumentParser(description='gTabData - GTK Tabular Data viewer', formatter_class=argparse.RawDescriptionHelpFormatter)
	parser.add_argument('--title', type=str, default='gTabData', help='Window title text')
	parser.add_argument('--appname', type=str, default='gtabdata', help='Custom application name to operate as')
	parser.add_argument('--appinstance', type=str, default='gtabdata', help='Custom application instance name to operate as')
	parser.add_argument('--icon', type=str, default='text-spreadsheet', help='Window icon file or symbolic name')
	data_group = parser.add_mutually_exclusive_group()
	data_group.add_argument('--data-command', type=str, metavar='COMMAND', help='The command which produces the tabular data to be shown')
	data_group.add_argument('--data-script', type=str, metavar='SCRIPT', help='Shell command(s) to produce tabular data')
	data_group.add_argument('--db-query', type=str, help='Database query to load data from')
	parser.add_argument('--db-connection', type=str, help='Database connection string, for supported DSN see "sqlalchemy" python module.')
	key_group = parser.add_mutually_exclusive_group()
	key_group.add_argument('--key-field', type=str, default=None, metavar='COLUMN')
	key_group.add_argument('--auto-key-field', action='store_true', default=False, help='Default key field is the first column in the input data.')
	parser.add_argument('--activate-command', type=str, metavar='COMMAND', help='System command to run when double clicked on a row.')
	parser.add_argument('--context-menu', action='append', default=[], type=str, metavar='ICON:LABEL:MENUITEM-OPTIONS:COMMAND', help='Menu item definitions for rows context menu.')
	parser.add_argument('--auto-refresh-interval', type=float, metavar='SEC')
	parser.add_argument('--inotify-refresh', type=str, metavar='FILE', help='')  # TODO
	parser.epilog = '''
ICON is one of these:
	- image file path
	- Gtk stock icon constant, starting with "STOCK_"
	- icon name as defined in the current Gtk icon theme
	- basename of an image file in the common system icon directories
LABEL is a jinja2 template rendered to the menu item label, supporting these variables:
	- n_selected: number of selected rows
	- cell: the cell's text content on which the context menu is opened
	- column: the column name in which the context menu is opened
	- row: a dict holding the focused/activated row's fields
	Literal ":" should be escaped by backslash.
	If the rendered LABEL is empty string, the menu item won't be shown.
	If the rendered LABEL starts with a space, the menu item is shown disabled.
	May create nested menus (submenus) by using "//" (couble slash) as a separator in LABEL to describe the path through the menu hierarchy.
	Parent menus are implicit, but if want to define icon for one, end its LABEL with "//" (double slash).
MENUITEM-OPTIONS
	Comma-delimited list of zero or more options:
	- per-each-selected-row: run the COMMAND separately on each row. Default is to run COMMAND once (and pass 'selected_rows' in JSON on its STDIN)
COMMAND
	The COMMAND option parameter is a jinja2 template, after rendered, split by whitespaces into command and arguments, no quoting or escaping is supported.
	Then the command is run as a system command, not in shell.
	For available jinja2 variables, see LABEL paragraph below.
	A JSON object is passed to the command's STDIN with these keys:
	- row: an object itself containing all fields (as object keys) and cells (as values) of the activated/focused row.
	- column: column's name which the context menu is opened on.
	- selected_rows: list of all the selected rows. Rows are dicts as in the 'row' top-level key.
'''
	return parser.parse_args()


cliargs = parse_cli_args()
APPNAME = cliargs.appname + '.' + cliargs.appinstance


class GTabData(object):
	def __init__(self):
		self.tabdata_key_field = None
		self._load_table_thread_name = 'load_table'

		self.main_win = Window({'name': 'window.main', 'gtk-args': [], 'default-size': ()})
		self.window_signalmanager = GSignalHandlerManager(self.main_win)
		self.window_signalmanager.connect('delete-event', lambda *X: self.on_exit())
		self.window_signalmanager.connect_once('map-event', lambda w, e: self._on_startup())
		add_key_binding(self.main_win, 'F5', lambda *X: self.load_table_async())

		self.main_table = TreeView(None)
		self.main_win.add(Scrollable(self.main_table))
		self.main_table.connect('row-activated', on_table_row_activated)
		self.main_table.connect('menu-popup', self.on_table_row_context_menu_open)
		self.main_table.connect('column-added', self.on_column_added)
		self.main_table.connect('key-press-event', self.on_key_press)

		self.proppersist_table = PropertyPersistor(self.main_table, 'main_table', [
			('columns-order',  'columns-changed',           lambda tv: merge_ordering(self.proppersist_table.props.get('columns-order') or [], [col.name for col in tv.get_columns()]), self.restore_columns_order),
			('hidden-columns', 'column-visibility-changed', lambda tv, tvc: [col.name for col in tv.get_columns() if not col.get_visible()], self.restore_hidden_columns),
			('column-width',   'column-width-changed',      lambda tv, tvc, tvc_width: dict([(col.name, col.get_width()) for col in tv.get_columns()]), self.restore_columns_width),
			('sort-column',    'sort-by-column-changed',    lambda tv, tvc: tvc.name if tvc is not None else None, self.restore_sortby_column),
			('sort-order',     'column-sort-order-changed', lambda tv, tvc: tvc.get_sort_order().value_nick if tvc is not None else None, None),
		])
		if cliargs.key_field is not None or cliargs.auto_key_field:
			self.proppersist_table.add_properties([('selected-rows', 'selection-change', lambda tv, sel_rows: [row[self.tabdata_key_field] for row in sel_rows], self.restore_selection)])
		self.proppersist_column = {}
		
	def run(self):
		self.main_win.show_all()

	def _on_startup(self):
		self.load_table_async()
	
	def load_table_async(self):
		if not self.table_is_loading:
			Thread(target=self.load_table, daemon=True, name=self._load_table_thread_name).start()
	
	@property
	def table_is_loading(self):
		return self._load_table_thread_name in [thr.name for thr in threading.enumerate()]
	
	def load_table(self):
		if cliargs.db_query:
			import sqlalchemy

			db_engine = sqlalchemy.create_engine(cliargs.db_connection, execution_options={'stream_results':True})
			db_conn = db_engine.connect()
			db_result = db_conn.execute(cliargs.db_query)

			columns = [(col, unicode) for col in db_result.keys()]
			self.load_columns(columns)
			data_generator = ((None, row) for row in db_result)
			self.load_data(data_generator)
		
		elif cliargs.data_command or cliargs.data_script:
			if cliargs.data_command:
				command = split_command_args(cliargs.data_command)
				in_shell = False
			elif cliargs.data_script:
				command = cliargs.data_script
				in_shell = True
			else:
				raise ValueError()

			try:
				proc = spawn_subprocess(command, shell=in_shell, stdin=open(os.devnull, 'r'), stdout=subprocess.PIPE, stderr=subprocess.PIPE, close_fds=True)
				td_header = tabdata(proc.stdout.readline())
				columns = [(col, unicode) for col in td_header]
				self.load_columns(columns)
				data_generator = ((None, tabdata(line, n_fields=len(columns))) for line in iter(proc.stdout.readline, ''))
				self.load_data(data_generator)
				proc.stdout.close()
				wait_subprocess(proc)
			except SubprocessError as err:
				with GtkThreadContext():
					ErrorMessage("Command failed with %s: <tt>%s</tt>\nDetails:" % (err.type, err.code), title="gTabData: execution error", details=err.details)
		
		with GtkThreadContext():
			self.after_load_table()
	
	def load_columns(self, columns):
		if cliargs.auto_key_field and self.tabdata_key_field is None:
			if columns[0][0] != '':
				self.tabdata_key_field = columns[0][0]
				print("info: Taking '%s' as key field." % self.tabdata_key_field, file=sys.stderr)
		
		if self.main_table.get_model() is None or columns != self.main_table.get_model().get_columns():
			with GtkThreadContext():
				with TemporaryProperty((self.proppersist_table, 'active'), (), False):
					self.main_table.set_model(TreeStore(*columns))
					self.main_table.set_columns([(col[0], col[0], 'text', idx) for idx, col in enumerate(columns)])
		
		if not cliargs.auto_key_field and cliargs.key_field is not None:
			if cliargs.key_field not in [col[0] for col in columns]:
				print("warning: Field '%s' is not in the input." % cliargs.key_field, file=sys.stderr)
			else:
				self.tabdata_key_field = cliargs.key_field

	def load_data(self, data_rows_iterator):
		cb_data = {
			'existing_records_keys': [],
			'model': self.main_table.get_model(),
		}
		if self.tabdata_key_field is None:
			with GtkThreadContext():
				cb_data['model'].clear()

		data_processor = TimedChunkProcessor(
			chunk_starter = lambda func: gobject.idle_add(glib_callback_once, func),
			iterator = data_rows_iterator,
			loop_context = CompositeContext(GtkThreadContext(), GDKCursor(self.main_win.window, gtk.gdk.WATCH)),
			loop_func = self.load_data_row,
			callback_param = cb_data,
			timebox_sec = 0.4)
		data_processor.run()
		data_processor.join()

		if self.tabdata_key_field is not None:
			with GtkThreadContext(), GDKCursor(self.main_win.window, gtk.gdk.WATCH):
				def remove_invalid_rows(model, treepath, treeiter, cb_data):
					if model[treepath][cb_data['tabdata_key_field']] not in cb_data['existing_records_keys']:
						del model[treepath]
				cb_data['model'].foreach(remove_invalid_rows, {'existing_records_keys': cb_data['existing_records_keys'], 'tabdata_key_field': self.tabdata_key_field})

	def load_data_row(self, loop_var, context_handlers, cb_data):
		treepath, row = loop_var
		record_key = None
		existing_record_path = None
		if self.tabdata_key_field is not None:
			record_key = row[cb_data['model'].get_column_num(self.tabdata_key_field)]
			existing_record_path = get_path_by_cell(cb_data['model'], search_column=self.tabdata_key_field, search_content=record_key)
		if existing_record_path is None:
			cb_data['model'].append(treepath, row)
		else:
			cb_data['model'][existing_record_path].update(row)
		if self.tabdata_key_field is not None:
			cb_data['existing_records_keys'].append(record_key)

	def after_load_table(self):
		with TemporaryProperty((self.proppersist_table, 'active'), (), False):
			self.proppersist_table.apply_saved_properties()
			# auto size newly learned columns
			self._auto_size_new_columns()
			# resize the app window if not yet resized by the user
			gobject.idle_add(glib_callback_once, self._window_initial_resize)
	
	def on_key_press(self, tv, event):
		key = gtk.gdk.keyval_name(event.keyval)
		treepath, col = tv.get_cursor()
		if treepath is None: return False
		if key == 'Menu':
			context_menu = gtk.Menu()
			self.on_table_row_context_menu_open(tv, context_menu, treepath, col, 0, 0)
			context_menu.show_all()
			context_menu.popup(None, None, lambda menu, cb_data: self.cell_coordinates(treepath, col, gtk.CORNER_BOTTOM_LEFT) + (True,), MOUSE_BUTTON_RIGHT, event.time, {})
			return True
	
	def cell_coordinates(self, treepath, col, corner):
		rect = self.main_table.get_cell_area(treepath, col)
		win_x, win_y = self.main_table.get_bin_window().get_origin()
		return win_x + rect.x + rect.width * int(corner.value_nick.endswith('right')), win_y + rect.y + rect.height * int(corner.value_nick.startswith('bottom'))

	def on_table_row_context_menu_open(self, treeview, popup_menu, c_treepath, tv_col, cell_x, cell_y):
		focus_data = gen_focus_data(treeview, c_treepath, tv_col)
		popup_menu.set_data('focus-data', focus_data)
		n_selected = len(focus_data['selected_rows'])
		macros = focus_data.copy()
		macros['n_selected'] = n_selected
		# add user-defined menu items
		populate_row_context_menu(popup_menu, cliargs.context_menu, macros)
		
		# add gtabdata-specific menu items:
		if popup_menu.get_children():
			popup_menu.append(gtk.SeparatorMenuItem())
		mi = ImageMenuItem(label="Copy cell", icon=gtk.STOCK_COPY)
		mi.connect('activate', on_context_menu_copy, popup_menu, 'cell')
		popup_menu.append(mi)
		mi = ImageMenuItem(label="Copy row as JSON", icon=gtk.STOCK_COPY)
		mi.connect('activate', on_context_menu_copy, popup_menu, 'row-as-json')
		popup_menu.append(mi)
		if n_selected > 1:
			mi = ImageMenuItem(label="Copy selection as JSON", icon=gtk.STOCK_COPY)
			mi.connect('activate', on_context_menu_copy, popup_menu, 'selection-as-json')
			popup_menu.append(mi)
		mi = ImageMenuItem(label="Refresh table data", icon=gtk.STOCK_REFRESH)
		mi.set_sensitive(not self.table_is_loading)
		mi.connect('activate', lambda mi: main_app.load_table_async())
		popup_menu.append(mi)
		return False


	def _window_initial_resize(self):
		if not self.main_win.property_persistor.props.get('geometry'):
			tv_width, tv_height = self.main_table.size_request()
			scr = self.main_win.get_screen()
			self.main_win.resize(min(tv_width, scr.get_width()), min(tv_height, scr.get_height()))
	
	def _auto_size_new_columns(self):
		self.main_table.columns_autosize([col for col in self.main_table.get_columns() if not col.get_width() or col.get_width() == 1])

	def on_column_added(self, tv, tvc):
		# restore width
		width = self.proppersist_table.props.get('column-width', {}).get(tvc.name, None)
		if width > 1:
			tvc.set_fixed_width(width)
		# restore visibility (hidden or not)
		if tvc.name in self.proppersist_table.props.get('hidden-columns', []):
			tvc.set_visible(False)
		# restore sort-by column
		if self.proppersist_table.props.get('sort-column') == tvc.name:
			tv.set_sortby_column_by_name(tvc.name)
			self.restore_sort_order_on_current_sortby_column

		
		# column-specific properties
		self.proppersist_column[tvc.name] = PropertyPersistor(tvc, 'column.'+tvc.name, [
			('font',      'font-changed',      lambda tvc, font_str: font_str,
				lambda tvc, font_str: tvc.set_font_desc(font_str)),
			('alignment', 'alignment-changed', lambda tvc, alignment_str: alignment_str,
				lambda tvc, alignment_str: tvc.set_text_alignment(getattr(gtk, 'JUSTIFY_'+alignment_str.upper()))),
			('filter',    'filter-expression-changed', lambda tvc, filter_expr: filter_expr,
				lambda tvc, filter_expr: tvc.set_filter_expr(filter_expr))
		])
		self.proppersist_column[tvc.name].apply_saved_properties()
		

	def restore_columns_width(self, tv, cols_width):
		for colname, width in cols_width.iteritems():
			if width > 1:
				try:
					tv.get_column_by_name(colname).set_fixed_width(width)
				except TreeView.ColumnNotFoundException:
					pass
	
	def restore_sortby_column(self, tv, colname):
		try:
			tv.set_sortby_column_by_name(colname)
		except TreeView.ColumnNotFoundException:
			pass
		else:
			self.restore_sort_order_on_current_sortby_column()
	
	def restore_sort_order_on_current_sortby_column(self):
		sort_order = self.proppersist_table.props.get('sort-order')
		if sort_order:
			self.main_table.get_sortby_column().set_sort_order(getattr(gtk, 'SORT_'+sort_order.upper()))
		
	def restore_hidden_columns(self, tv, columns):
		for colname in columns:
			try:
				tv.get_column_by_name(colname).set_visible(False)
			except TreeView.ColumnNotFoundException:
				pass

	def restore_columns_order(self, tv, columns):
		preceding_col = None
		for colname in columns:
			try:
				col = tv.get_column_by_name(colname)
			except TreeView.ColumnNotFoundException:
				pass
			else:
				tv.move_column_after(col, preceding_col)
				preceding_col = col
	
	def restore_selection(self, tv, selected_records_keys):
		last_treepath = None
		if self.tabdata_key_field is not None:
			for key in selected_records_keys:
				treepath = get_path_by_cell(tv.get_model(), search_column=self.tabdata_key_field, search_content=key)
				if treepath is not None:
					tv.get_selection().select_path(treepath)
					last_treepath = treepath
		if last_treepath is not None:
			tv.scroll_to_cell(last_treepath)

	def on_exit(self):
		self.proppersist_table.active = False
		gtk.main_quit()


main_app = GTabData()
main_app.main_win.title = Template(cliargs.title).render({'env': os.environ})
main_app.main_win.set_icon_from_any(cliargs.icon)
main_app.main_win.set_wmclass(cliargs.appname, cliargs.appinstance)
main_app.run()
gtk.main()
