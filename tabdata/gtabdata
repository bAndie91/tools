class ImageMenuItem(gtk.ImageMenuItem, MenuItem):
	def __init__(self, stock_id=None, accel_group=None, label=None, markup=None, icon=None):
		assert not(label is not None and markup is not None), "label and markup arguments are mutually exclusive"
		super(ImageMenuItem, self).__init__(stock_id=stock_id, accel_group=accel_group)
		if label is not None:
			self.set_label(label)
		if markup is not None:
			self.set_markup(markup)
		if icon is not None:
			self.set_icon(icon)
	def set_icon(self, icon):
		if not icon: return
		img = gtk.Image()
		if os.path.isfile(icon):
			width_px, height_px = gtk.icon_size_lookup(gtk.ICON_SIZE_MENU)[:]
			pixbuf = get_pixbuf_from_file_at_size(icon, width_px, height_px)
			img.from_pixbuf(pixbuf)
		elif icon.startswith('STOCK_'):
			img.set_from_stock(getattr(gtk, icon), gtk.ICON_SIZE_MENU)
		elif icon in gtk.stock_list_ids():
			img.set_from_stock(icon, gtk.ICON_SIZE_MENU)
		elif gtk.icon_theme_get_default().lookup_icon(icon, gtk.ICON_SIZE_MENU, 0) is not None:
			img.set_from_icon_name(icon, gtk.ICON_SIZE_MENU)
		else:
			width_px, height_px = gtk.icon_size_lookup(gtk.ICON_SIZE_MENU)[:]
			iconfile = find_icon_file(icon, width_px)
			if iconfile is None: return
			pixbuf = get_pixbuf_from_file_at_size(iconfile, width_px, height_px)
			img.set_from_pixbuf(pixbuf)
		self.set_image(img)


class TemporaryProperty(object):
	"""Context manager to temporarily set an object property and restore it on exit."""
	def __init__(self, getter, setter, tempval):
		assert callable(getter) or len(getter)==2
		assert callable(setter) or setter is () or len(setter)==2
		self.getter = getter
		self.setter = setter
		self.tempval = tempval
		self.original = None
	
	def _set(self, x):
		if callable(self.setter):
			self.setter(x)
		elif self.setter is ():
			setattr(self.getter[0], self.getter[1], x)
		else:
			setattr(self.setter[0] if self.setter[0] is not None else self.getter[0], self.setter[1], x)

	def __enter__(self):
		if callable(self.getter):
			self.original = self.getter()
		else:
			self.original = getattr(self.getter[0], self.getter[1])
		self._set(self.tempval)
		return self
	
	def __exit__(self, exc_type, exc_val, exc_tb):
		self._set(self.original)


class GtkThreadProtectedContext(object):
	def __init__(self, parent_context):
		self.parent_context = parent_context
	def __enter__(self):
		self.parent_context.enter()
		return self
	def __exit__(self, exc_type, exc_val, exc_tb):
		self.parent_context.leave_maybe()
		return False

class GtkThreadContext(object):
	def __init__(self, max_freeze_sec=None):
		self._entered = False
		self.max_freeze_sec = max_freeze_sec
		if self.max_freeze_sec is not None:
			self._last_enter = 0
			self.protected = GtkThreadProtectedContext(parent_context=self)
	def __enter__(self):
		if self.max_freeze_sec is None:
			self.do_enter()
		return self
	def do_enter(self):
		if not self._entered:
			gtk.threads_enter()
			self._entered = True
			self._last_enter = time.time()
	def __exit__(self, exc_type, exc_val, exc_tb):
		self.do_leave()
		return False  # don't ignore exceptions
	def do_leave(self):
		if self._entered:
			gtk.threads_leave()
			self._entered = False
	def leave_maybe(self):
		if self._last_enter + self.max_freeze_sec < time.time():
			self.do_leave()
	def enter(self):
		self.do_enter()

class NoGtkThreadContext(object):
	def __enter__(self):
		gtk.threads_leave()
		return self
	def __exit__(self, exc_type, exc_val, exc_tb):
		gtk.threads_enter()

class GDKCursor(object):
	def __init__(self, gdk_window, cursor):
		self.window = gdk_window
		self.prev_cursor = self.window.get_cursor()
		self.this_cursor = cursor if isinstance(cursor, gtk.gdk.Cursor) else gtk.gdk.Cursor(self.window.get_display(), cursor)
	def __enter__(self):
		return self.window.set_cursor(self.this_cursor)
	def __exit__(self, exc_type, exc_val, exc_tb):
		self.window.set_cursor(self.prev_cursor)
		return False  # don't ignore exceptions

class CompositeContext(object):
    def __init__(self, *contexts):
        self.contexts = contexts

    def __enter__(self):
        return tuple(ctx.__enter__() for ctx in self.contexts)

    def __exit__(self, exc_type, exc_val, exc_tb):
        suppressed = False
        for ctx in reversed(self.contexts):
            try:
                if ctx.__exit__(exc_type, exc_val, exc_tb):
                    suppressed = True
                    exc_type = exc_val = exc_tb = None
            except Exception:
                import sys
                exc_type, exc_val, exc_tb = sys.exc_info()
                suppressed = False
        return suppressed

class NoneContext(object):
	def __enter__(self):
		return self
	def __exit__(self, exc_type, exc, tb):
		return False

class TimedChunkProcessor(object):
	def __init__(self, chunk_starter, iterator, loop_func, timebox_sec, loop_context=NoneContext(), callback_param=None):
		self.chunk_starter = chunk_starter
		self.iterator = iterator
		self.loop_context = loop_context
		self.loop_func = loop_func
		self.callback_param = callback_param
		self.timebox_sec = timebox_sec
		self.finish_event = threading.Event()
	def run(self):
		self.chunk_starter(self._callback)
	def _callback(self):
		continue_processing = True
		chunk_start = time.time()
		with self.loop_context as context_handler:
			while True:
				try:
					loop_var = self.iterator.next()
				except StopIteration:
					continue_processing = False
					break
				else:
					self.loop_func(loop_var, context_handler, self.callback_param)
				if chunk_start + self.timebox_sec < time.time():
					break
		if continue_processing:
			self.run()
		else:
			self.finish_event.set()
	def join(self):
		self.finish_event.wait()

class Thread(threading.Thread):
	def __init__(self, *params, **opts):
		is_daemon = None
		if 'daemon' in opts:
			is_daemon = opts['daemon']
			del opts['daemon']
		super(Thread, self).__init__(*params, **opts)
		if is_daemon:
			self.setDaemon(is_daemon)

class SubprocessError(Exception):
	def __init__(self, typ=None, code=None, details=''):
		super(SubprocessError, self).__init__()
		self.type = typ
		self.code = code
		self.details = details

def spawn_subprocess(command_with_args, *popen_args, **popen_options):
	err = SubprocessError()
	command_str = command_with_args if isinstance(command_with_args, basestring) else subprocess.list2cmdline(command_with_args)
	try:
		proc = subprocess.Popen(command_with_args, *popen_args, **popen_options)
	except Exception as exc:
		err.type = "exception"
		err.code = exc.__class__.__name__
		err.details = 'command: '+command_str
		err.details += "\n" + traceback.format_exc()
		if isinstance(exc, OSError):
			err.type = "status code"
			err.code = exc.errno
			err.details = exc.strerror + "\n" + err.details
			if exc.filename is not None: 
				err.details = "file: " + exc.filename + "\n" + err.details
		raise err
	else:
		proc.command_str = command_str
	return proc

def wait_subprocess(proc):
	err = SubprocessError()
	stderr = proc.stderr.read()
	if stderr:
		print(stderr, file=sys.stderr)
	proc.stderr.close()
	proc.wait()
	err.details = 'command: ' + proc.command_str + '\n'
	err.details += 'subprocess.Popen().returncode: ' + str(proc.returncode) + '\n'
	if stderr:
		err.details += 'stderr:\n' + stderr
	else:
		err.details += '(no stderr)'
	if proc.returncode != 0:
		err.type = "status code" if proc.returncode > 0 else "signal"
		err.code = abs(proc.returncode)
		raise err
	return proc

def ErrorMessage(message_markup, title=None, details=None):
	dlg = gtk.MessageDialog(parent=main_app.main_win, flags=(gtk.DIALOG_MODAL | gtk.DIALOG_DESTROY_WITH_PARENT), type=gtk.MESSAGE_ERROR, buttons=gtk.BUTTONS_OK)
