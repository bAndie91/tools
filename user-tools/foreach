#!/usr/bin/env perl

=pod

=head1 NAME

foreach - Run a command on each input line, similar to xargs(1)

=head1 SYNOPSIS

foreach [I<OPTIONS>] I<COMMAND> [I<ARGS> ...]

=head1 DESCRIPTION

Take each input line from stdin as B<DATA>, and run I<COMMAND> with B<DATA> appended to the end of I<ARGS> as a single argument.

If C<{}> is there in I<ARGS> then it's substituted with B<DATA> rather than append to the end,
unless I<--no-placeholder> is given, because then C<{}> is taken literally.
Additionally, foreach(1) parses B<DATA> into fields and add each of them to the end of I<ARGS> if I<--fields> is given.
Numbered placeholders, like C<{0}>, C<{1}>, ... are substituted with the respective field's value.
If the input data has less fields, higher numbered fields are considered empty string.
A stand-alone C<{@}> ("at" sign surrounded by curly brackets) argument is substituted to all fields of the input,
into separete arguments, but only if C<{@}> stands as its own separate argument.

So, for example, if you have not specified any I<ARGS> in the command line and type both I<--data> and I<--fields>,
then B<DATA> goes into argv[1], and the first field goes into argv[2], second to argv[3] and so on (argv[0] being the command name iteself). If 1 argument is in I<ARGS>, then the rest is shifted by 1, ie. B<DATA> goes into argv[2], etc.
If have not given I<--data> nor I<--fields>, then I<--data> is implied.

If called with B<--sh> option, I<COMMAND> is run by the shell.
Both in B<--sh> mode and system-command mode,
input line goes to C<DATA>,
individual fields go to C<F0>, C<F1>, ... environment variables;
and C<< TD_I<COLUMN1> >>, C<< TD_I<COLUMN2> >>, ... environment variables if I<--tabdata> is given, where I<COLUMN1>, I<COLUMN2>, ... are the column names.

Set B<-d> I<DELIM> if you want to split B<DATA> not by the occurrance of TAB and SPACE chars but by other chars,
eg. B<-d ',:'> for comma and colon.
There is also B<--tab> option to set delimiter to TAB for your convenience; but this is implied in B<--tabdata> mode.

=head1 OPTIONS

=over 4

=item -e, --sh

I<COMMAND> is interpreted as a shell script and run by the shell (determined by the B<SHELL> environment variable).

=item -l, --data

Pass B<DATA> in the arguments after the user-specified I<ARGS>.

=item -f, --fields

Pass individual fields of B<DATA> in the arguments after B<DATA> if I<--data> is given,
or after the user-specified I<ARGS> if I<--data> is not given.

=item -i, --input I<DATA>

Don't read any B<DATA> from stdin, but take I<DATA> given at B<--input> option(s).
This option is repeatable.

=item -d, --delimiter I<DELIM>

Cut up B<DATA> into fields at I<DELIM> chars.
Default is TAB and SPACE.

=item -D, --delim-regex, --delimiter-regex I<PATTERN>

Cut up B<DATA> into fields by I<PATTERN> (perl) regular expression.
Default is to split by the occurrance of TAB and SPACE chars.

=item -t, --tab

Cut up B<DATA> into fields at TAB chars..

=item --tabdata, --td

Input is tabular data with column names in the header (first line).
Replace C<< {I<COLUMN>} >> references in I<ARGS> (and I<COMMAND>) to the given I<COLUMN>'s field value.
Non-existing columns are considered empty string.
Column names should not be integers, so they won't conflict with C<< {I<NUMBER>} >> placeholders,
which are substituted to the respective field's value even in B<--tabdata> mode as well.
Implies B<--tab> option.
The C<{}> and C<{@}> placeholders are still substituted in.

=item -P, --no-placeholder

Do not substitute any placeholders (which are in curly braces).

=item -p, --prefix I<TEMPLATE>

Print something before each command execution.
I<TEMPLATE> is interpolated like I<COMMAND> and I<ARGS>,
so it may contain C<{}> and C<< {I<NUMBER>} >> (and C<< {I<COLUMN>} >> in B<--tabdata> mode).

=item --prefix-add I<TEMPLATE>

Append I<TEMPLATE> to the prefix template.
See B<--prefix> option.

=item --prefix-add-data

Add B<DATA> to the prefix which is printed before each command execution.
See B<--prefix> option.

=item --prefix-add-tab

Add a B<TAB> char to the prefix which is printed before each command execution.
See B<--prefix> option.

=item -v, --verbose

=item -n, --dry-run

=item -E, --errexit

Stop executing if a I<COMMAND> returns non-zero.
Rather exit with the said command's exit status code.

=back

=head1 EXAMPLES

 ls -l --time-style +%FT%T%z | foreach --data --fields sh -c 'echo size: $5, file: $7'
 ls -l --time-style +%FT%T%z | foreach --sh 'echo size: $F4, file: $F6'

=head1 LIMITS

Placeholders for field values (C<{0}>, C<{1}>, ...) are considered from 0 up to 99.
There must be a limit somewhere, otherwise I had to write a more complex replace routine.

=head1 CAVEATS

Placeholder C<{}> is substituted in all I<ARGS> anywhere, not just stand-alone C<{}> arguments,
but IS NOT ESCAPED!
So be careful using it in shell command arguments like C<sh -e 'echo "data is: {}"'>.

=head1 SEE ALSO

xargs(1), xe(1) L<https://github.com/leahneukirchen/xe>, apply(1), xapply(1) L<https://www.databits.net/~ksb/msrc/local/bin/xapply/xapply.html>

=cut


use Data::Dumper;
use utf8;
use open ':std', ':utf8';  # mark stdio as utf8 but not verify
use open ':utf8';
use Errno qw/:POSIX/;
use Getopt::Long qw/:config no_ignore_case no_bundling no_getopt_compat no_auto_abbrev pass_through permute/;
use IPC::Run qw/run/;
use List::MoreUtils qw/all any none/;
use Pod::Usage;
no if ($] >= 5.018), 'warnings' => 'experimental::smartmatch';
do '/usr/lib/tool/perl5/tabdata/common.pl' or die "$@";


# If the string $S is a well-behaved file name, simply return it.
# If it contains white space, quotes, etc., quote it, and return the new string.
sub shell_quote($)
{
  my ($s) = @_;
  if ($s =~ m![^\w+/.,-]!)
    {
      # Convert each single quote to '\''
      $s =~ s/\'/\'\\\'\'/g;
      # Then single quote the string.
      $s = "'$s'";
    }
  return $s;
}


$OptVerbose = 0;
$OptMode = 'command';
$DefaultDelimChars = "\t ";
$OptDelimChars = undef;
$OptDelimRegex = undef;
$OptTabdata = 0;
$OptPassData = undef;
$OptPassFields = 0;
$OptReplacePlaceholder = 1;
$OptDryRun = 0;
$OptErrExit = 0;
$OptPrefixTemplate = '';
@OptInputData = ();


GetOptions(
	'e|sh!' => sub { $OptMode = 'shell'; },
	'l|data!' => \$OptPassData,
	'f|fields!' => \$OptPassFields,
	'i|input=s@' => \@OptInputData,
	'd|delimiter=s' => \$OptDelimChars,
	'D|delim-regex|delimiter-regex=s' => \$OptDelimRegex,
	't|tab' => sub { $OptDelimChars = '\t'; },
	'td|tabdata' => sub {
		if((defined $OptDelimChars and $OptDelimChars ne "\t") or (defined $OptDelimRegex and $OptDelimRegex ne "\t"))
		{
			die "foreach: with option --tabdata TAB should be used as field delimiter\n";
		}
		$OptTabdata = 1;
		$OptDelimChars = "\t";
	},
	'P|no-placeholder' => sub { $OptReplacePlaceholder = 0; },
	'p|prefix=s' => \$OptPrefixTemplate,
	'prefix-add=s' => sub { $OptPrefixTemplate .= $_[1]; },
	'prefix-add-data' => sub { $OptPrefixTemplate .= '{}'; },
	'prefix-add-tab' => sub { $OptPrefixTemplate .= "\t"; },
	'v|verbose!' => \$OptVerbose,
	'n|dry-run!' => \$OptDryRun,
	'E|errexit!' => \$OptErrExit,
	'help' => sub { pod2usage(-exitval=>0, -verbose=>99); },
	'<>' => sub { unshift @ARGV, $_[0]; die '!FINISH'; },
) or pod2usage(-exitval=>2, -verbose=>99);


if(not defined $OptDelimRegex)
{
	if(not defined $OptDelimChars)
	{
		$OptDelimChars = $DefaultDelimChars;
	}
	$DelimRegex = '[' . quotemeta($OptDelimChars) . ']';
}

if($OptPassFields and not $OptPassData)
{
	$OptPassData = 0;
}
if(not $OptPassFields)
{
	$OptPassData = 1;
}

$SHELL = $ENV{'SHELL'} // 'sh';
@Command = @ARGV;
$OptInputDataIndex = 0;

sub next_data
{
	if(@OptInputData)
	{
		if($OptInputDataIndex >= scalar @OptInputData)
		{
			return undef;
		}
		my $data = $OptInputData[$OptInputDataIndex];
		$OptInputDataIndex++;
		return $data;
	}
	else
	{
		my $data = <STDIN>;
		return undef if not defined $data;
		chomp $data;
		return $data;
	}
}

sub placeholder_replacement
{
	my $var = shift;
	my $data = shift;
	my $field_ref = shift;
	my @field = @$field_ref;
	my $column_ref = shift;
	my @column = @$column_ref;

	if($var eq '')
	{
		return $data;
	}
	elsif($var =~ /^\d+$/)
	{
		return $field[$var] // '';
	}
	elsif($OptTabdata)
	{
		my $idx = 0;
		for my $col (@column)
		{
			if($col eq $var)
			{
				return $field[$idx] // '';
			}
			$idx++;
		}
	}
	return '';
}

if($OptTabdata)
{
	@Column = map { unescape_tabdata($_) } split $DelimRegex, next_data();
}

while(defined (my $Data = next_data()))
{
	my @Field = split $DelimRegex, $Data;
	
	$ENV{'DATA'} = $Data;
	my $idx;
	for($idx = 0; $idx <= $#Field; $idx++)
	{
		$ENV{"F$idx"} = $Field[$idx] // '';
	}
	while(exists $ENV{"F$idx"})
	{
		delete $ENV{"F$idx"};
		$idx++;
	}
	undef $idx;
	if($OptTabdata)
	{
		for my $idx (0..$#Column)
		{
			$ENV{'TD_' . $Column[$idx]} = $Field[$idx] // '';
		}
	}

	my @cmd_args = ();
	my $placeholder_found = 0;

	if($OptReplacePlaceholder)
	{
		my @cmd_template = @Command;
		for my $arg (@cmd_template)
		{
			if($arg eq '{@}')
			{
				$placeholder_found = 1;
				push @cmd_args, @Field;
			}
			else
			{
				if($arg =~ s/\{(.*?)\}/placeholder_replacement($1, $Data, \@Field, \@Column)/eg)
				{
					$placeholder_found = 1;
				}
				push @cmd_args, $arg;
			}
		}
	}
	else
	{
		@cmd_args = @Command;
	}
	
	if($OptMode eq 'command')
	{
		if(not $OptReplacePlaceholder or not $placeholder_found)
		{
			if($OptPassData)
			{
				push @cmd_args, $Data;
			}
			if($OptPassFields)
			{
				push @cmd_args, @Field;
			}
		}
	}
	
	if($OptMode eq 'shell')
	{
		@cmd_args = ($SHELL, '-c', @cmd_args);
	}
	
	if($OptVerbose)
	{
		warn "foreach: ".join(' ', map {shell_quote($_)} @cmd_args)."\n";
	}
	
	print $OptPrefixTemplate =~ s/\{(.*?)\}/placeholder_replacement($1, $Data, \@Field, \@Column)/egr;

	my $RunStatus = 0;

	if(not $OptDryRun)
	{
		my @stdin_args = ();
		if(not @OptInputData)
		{
			@stdin_args = ('<', \undef);
		}
		run [@cmd_args], @stdin_args;
		$RunStatus = $?;
	}
	
	if($OptErrExit and $RunStatus != 0)
	{
		my $exit_error = WEXITSTATUS($RunStatus);
		$exit_error = 128 + WTERMSIG($RunStatus) if WIFSIGNALED($RunStatus);
		exit $exit_error;
	}
}
