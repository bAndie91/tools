		self.show_all()
	
	def manage_button_states(self):
		self.btn_set.set_active(self.clock.is_running)


class MultiClassColumn(gtk.VBox):
	__gsignals__ = {
		'item-added': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'item-removed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self, cls):
		super(self.__class__, self).__init__()
		self.cls = cls
		self._items = []

	def new_item(self, item=None):
		if item is not None and not isinstance(item, self.cls):
			raise ValueError("item should be of type %s" % self.cls)
		if item is None:
			item = self.cls()
		self._items.append(item)
		removable_box = gtk.HBox()
		removable_box.inner_widget = item
		button_remove = StockButton(stock=gtk.STOCK_REMOVE, label='')
		button_remove.connect('clicked', lambda X, removable_box: self.remove_item(removable_box), removable_box)
		removable_box.pack_start(item, expand=True, fill=True)
		removable_box.pack_start(button_remove, expand=False, fill=False)
		self.pack_start(removable_box, expand=False, fill=False)
		self.show_all()
		if hasattr(item, 'manage_button_states'):
			item.manage_button_states()
		self.emit('item-added', item)
	
	def remove_item(self, removable_box):
		item = removable_box.inner_widget
		if not item.clock.is_running:
			self.items.remove(item)
			item.clock.drain()
			item.destroy()
			removable_box.destroy()
			self.emit('item-removed')

	@property
	def items(self):
		return self._items

class MultiClassInstantiatorBox(gtk.HBox):
	__gsignals__ = {
		'item-added': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, (gobject.TYPE_PYOBJECT,)),
		'item-removed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self, classes):
		super(self.__class__, self).__init__(homogeneous=True, spacing=2)
		self._columns = []
		for cls in classes:
			column = MultiClassColumn(cls)
			add_widget_button = StockButton(stock=gtk.STOCK_ADD, label=cls.name)
			add_widget_button.connect('clicked', lambda X, column: column.new_item(None), column)
			column.pack_start(add_widget_button, expand=False, fill=False)
			self.pack_start(column, expand=False, fill=False)
			self._columns.append(column)
			column.connect('item-added', lambda col, item: self.emit('item-added', item))
			column.connect('item-removed', lambda col: self.emit('item-removed'))
		self.show_all()
	
	def add_item(self, item):
		"add the given item to the column corresponding to its type"
		for col in self._columns:
			if isinstance(item, col.cls):
				col.new_item(item)
				return
		raise ValueError("No column for item of type %s" % type(item))

	@property
	def items(self):
		for col in self._columns:
			for item in col.items:
				yield item


