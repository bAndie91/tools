class Stopper(Clock):
	name = "Stopper"

	__gsignals__ = {
		'started': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'paused': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'change': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self):
		self._start_time = None
		self._behind_interval = 0
		self._running = False
		self._last_paused_time = None
		super(self.__class__, self).__init__()

	def run(self):
		if not self._running:
			now = time.time()
			if self._start_time is None:
				self._start_time = now
			if self._last_paused_time is not None:
				self._behind_interval += now - self._last_paused_time
			self._running = True
			self.emit('change')
			self.emit('started')
			self._update()

	def pause(self):
		if self._running:
			self._last_paused_time = time.time()
			self._running = False
			self.emit('change')
			self.emit('paused')
			self._update()

	def _next_update_interval_ms(self):
		return 10

	def update_display(self):
		if self._start_time > 0:
			if self._running:
				display_time = time.time() - self._start_time - self._behind_interval
			else:
				display_time = self._last_paused_time - self._start_time - self._behind_interval
			hours = display_time / 3600
			face = '%s%02d:%02d.%02d' % (
				('%dh ' % hours) if hours >= 1 else '',
				display_time / 60 % 60,
				display_time % 60,
				(display_time - int(display_time)) * 100,
			)
		else:
			face = '00:00.00'
		self.set_markup("<span size='32000'><b>" + face + "</b></span>")

	def to_dict(self):
		return {
		  'start_time': self._start_time, 
		  'last_paused_time': self._last_paused_time, 
		  'behind_interval': self._behind_interval, 
		  'running': self.is_running,
		}

	@classmethod
	def from_dict(cls, state):
		instance = cls()
		instance._start_time = state.get('start_time')
		instance._last_paused_time = state.get('last_paused_time')
		instance._behind_interval = state.get('behind_interval')
		if state.get('running'):
			instance.run()
		return instance
	

class KitchenTimer(gtk.HBox, Clock):
	name = "Timer"

	__gsignals__ = {
		'started': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'stopped': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'due': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'change': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self):
		self.face = AdjustableClock()
		self.face.hours.range = (0, None)  # can set to more than 24 hours
		self.face.connect('user-changed', lambda *X: self.emit('change'))
		self.alarmer = Alarmer()
		super(gtk.HBox, self).__init__()
		super(Clock, self).__init__()
		self.pack_start(self.face, expand=False, fill=False)
		self.show_all()
		self._future_time = None

	@property
	def scheduled_time_interval_sec(self):
		return self.face.get_seconds()

	def start(self):
		if not self._running and not self.alarmer.alarmed:
			self.scheduled_time_components = self.face.components
			self.face.lock()
			self._future_time = time.time() + self.scheduled_time_interval_sec
			self._running = True
			self.emit('change')
			self.emit('started')

	def restore(self):
		self.face.lock()
		self._running = True
		self.emit('change')
		self.emit('started')

	def stop(self):
		self.face.format_labels(None, None, None)
		self._running = False
		self.emit('change')
		self.emit('stopped')

	def update_display(self):
		if self._running:
			display_time = self._future_time - time.time()
			if display_time <= 0:
				if not self.alarmer.alarmed:
					self.emit('due')
					self.alarmer.text = "Your %d:%02d:%02d timer is due!" % self.scheduled_time_components
					self.alarmer.alarm()
				self.face.format_labels(None, None, None, foreground='red')
			self.face.set_seconds(display_time)

	def to_dict(self):
		state = {
          'running': self.is_running, 
		}
		if state['running']:
			state['scheduled_time_components'] = self.scheduled_time_components
			state['alarm_set_time'] = self._future_time
		else:
			state['scheduled_time_interval_sec'] = self.scheduled_time_interval_sec
		return state

	@classmethod
	def from_dict(cls, state):
		instance = cls()
		if state.get('running'):
			instance.scheduled_time_components = tuple(state['scheduled_time_components'])
			instance._future_time = state['alarm_set_time']
			instance.face.set_seconds(state['alarm_set_time'] - time.time())
			instance.restore()
		else:
			instance.face.set_seconds(state['scheduled_time_interval_sec'])
		return instance

class AlarmClock(gtk.HBox, Clock):
	name = "Alarm"

	__gsignals__ = {
		'turned-on': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'turned-off': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'turned': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'alarm': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
		'change': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self):
		self.face = AdjustableClock()
		self.face.hours.range = (0, 23)
		super(gtk.HBox, self).__init__()
		super(Clock, self).__init__()
		self.pack_start(self.face, expand=False, fill=False)
		now = datetime.now()
		self.face.set(now.hour, now.minute, now.second)
		self.face.connect('user-changed', lambda *X: self.emit('change'))
		self.set_time = None
		self._running = False
		self.show_all()

	def turn_on(self, override_set_time=None):
		if not self._running:
			if override_set_time is not None:
				self.set_time = override_set_time
			else:
				now = datetime.now()
				h, m, s = self.face.components
				set_datetime = now.replace(hour=h, minute=m, second=s)
				if set_datetime < now:
					# if the set time is already passed for today, set it for tomorrow
					set_datetime += timedelta(days=1)
				self.set_time = int(set_datetime.strftime('%s'))
			self.face.lock()
			self.alarmer = Alarmer()
			self._running = True
			self.emit('change')
			self.emit('turned-on')
			self.emit('turned')

	def turn_off(self):
		if self._running:
			self.face.format_labels(None, None, None)
			self.face.unlock()
			self._running = False
			self.emit('change')
			self.emit('turned-off')
			self.emit('turned')

	def update_display(self):
		if self._running:
			now = time.time()
			if self.set_time <= now:
				if not self.alarmer.alarmed:
					self.emit('alarm')
					self.alarmer.text = "It's passed %02d:%02d:%02d !!" % self.face.components
					self.alarmer.alarm()
					self.turn_on()
				self.face.format_labels(None, None, None, foreground='red')

	def to_dict(self):
		state = {'set_time': self.set_time, 'running': self.is_running}
		return state

	@classmethod
	def from_dict(cls, state):
		instance = cls()
		if state.get('set_time') is not None:
			instance.set_time = float(state.get('set_time'))
			set_datetime = datetime.fromtimestamp(instance.set_time)
			instance.face.set(set_datetime.hour, set_datetime.minute, set_datetime.second)
			if state.get('running'):
				instance.turn_on(instance.set_time)
		return instance


class Alarmer(object):
	def __init__(self):
		self.alarmed = False
		self.title = 'Alarm'
		self.text = 'alarm!'

	def alarm(self):
		dialog = gtk.MessageDialog(flags=gtk.DIALOG_DESTROY_WITH_PARENT, type=gtk.MESSAGE_WARNING, buttons=gtk.BUTTONS_OK, message_format=self.title)
		dialog.set_type_hint(gtk.gdk.WINDOW_TYPE_HINT_TOOLBAR)
		dialog.set_keep_above(True)
		dialog.set_skip_taskbar_hint(False)
		dialog.set_icon_name('alarm-clock')
		dialog.get_image().set_from_icon_name('alarm-clock', gtk.ICON_SIZE_DIALOG)
		dialog.set_title(self.title)
		dialog.format_secondary_text(self.text)
		btn_ok = dialog.get_widget_for_response(gtk.RESPONSE_OK)
		btn_ok.connect('clicked', lambda *X: dialog.destroy())
		dialog.show_all()
		win_main.present()
		dialog.present()
		self.alarmed = True


class StopperUI(gtk.HBox):
	name = Stopper.name

	def __init__(self, *pargs, **kwargs):
		if 'clock' in kwargs:
			self.clock = kwargs['clock']
			del kwargs['clock']
		else:
			self.clock = Stopper()
		super(gtk.HBox, self).__init__(*pargs, **kwargs)
		self.btn_start = StockButton(stock=gtk.STOCK_MEDIA_PLAY, label='')
		self.btn_pause = StockButton(stock=gtk.STOCK_MEDIA_PAUSE, label='')
		self.btn_start.connect('clicked', lambda *X: self.clock.run())
		self.btn_pause.connect('clicked', lambda *X: self.clock.pause())
		self.pack_start(self.clock, expand=True, fill=True)
		self.pack_start(self.btn_start, expand=False, fill=False)
		self.pack_start(self.btn_pause, expand=False, fill=False)

		self.clock.connect('started', lambda *X: self.manage_button_states())
		self.clock.connect('paused', lambda *X: self.manage_button_states())
		self.manage_button_states()

	def manage_button_states(self):
		running = self.clock.is_running
		self.btn_start.set_sensitive(not running)
		self.btn_pause.set_sensitive(running)


