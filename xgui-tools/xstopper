def add_key_binding(widget, keyname, callback):
	accelgroup = gtk.AccelGroup()
	key, modifier = gtk.accelerator_parse(keyname)
	accelgroup.connect_group(key, modifier, gtk.ACCEL_VISIBLE, callback)
	widget.add_accel_group(accelgroup)


# Configuration helpers
STATE_DIR = os.environ.get('XDG_STATE_HOME') or os.path.expanduser('~/.local/state')
STATE_FILE = os.path.join(STATE_DIR, 'xstopper.json')
restoring_phase = False

def ensure_config_dir():
	try:
		os.makedirs(STATE_DIR, 0o700)
	except OSError as e:
		if e.errno != errno.EEXIST:
			raise

def restore_state():
	global restoring_phase
	try:
		state = json.load(open(STATE_FILE, 'r'))
	except Exception:
		traceback.print_exc()
		return
	restoring_phase = True
	for clock_state in state:
		clock_class = clock_state.get('class')
		clock = globals()[clock_class].from_dict(clock_state)
		clockui_class = clock_class + 'UI'
		clockui = globals()[clockui_class](clock=clock)
		multibox.add_item(clockui)
	restoring_phase = False

def save_state():
	global restoring_phase
	if restoring_phase:
		return
	states = []
	for clockui in multibox.items:
		clock = clockui.clock
		state = clock.to_dict()
		state.update({'class': clock.__class__.__name__})
		states.append(state)
	ensure_config_dir()
	with open(STATE_FILE, 'w') as f:
		json.dump(states, f)


def _strip_net_wm_ping(win):
	gdkwin = win.window  # the underlying GdkWindow
	# Read what GTK put in WM_PROTOCOLS
	result = gdkwin.property_get("WM_PROTOCOLS")
	if result is None:
		return
	# result is (type_atom, format, data) — data is a list of atom names
	_type, _format, atoms = result
	# Filter out _NET_WM_PING
	filtered = [a for a in atoms if a != "_NET_WM_PING"]
	# Write back
	gdkwin.property_change(
		gtk.gdk.atom_intern("WM_PROTOCOLS"),
		gtk.gdk.atom_intern("ATOM"),
		32,
		gtk.gdk.PROP_MODE_REPLACE,
		[gtk.gdk.atom_intern(a) for a in filtered])

def on_realize(widget):
	_strip_net_wm_ping(win_main)

class StockButton(gtk.Button):
	def __init__(self, label=None, stock=None, use_underline=True, icon_size=None, tooltip=None):
		if stock is not None and stock in gtk.stock_list_ids():
			stock_tmp = stock
		else:
			stock_tmp = gtk.STOCK_ABOUT
		super(self.__class__, self).__init__(stock=stock_tmp, use_underline=use_underline)
		if label is not None:
			self.set_markup(label)
		if stock is None:
			self.set_icon('')
		elif stock not in gtk.stock_list_ids():
			self.set_icon(stock)
		if icon_size is not None:
			self.set_icon(stock, icon_size)
		if tooltip is not None:
			self.set_tooltip_text(tooltip)
	def __get_children(self):
		align = self.get_children()[0]
		hbox = align.get_children()[0]
		return hbox.get_children()
	def set_label(self, label):
		x, lbl = self.__get_children()
		lbl.set_label(label)
	def set_markup(self, label):
		x, lbl = self.__get_children()
		lbl.set_markup(label)
	def set_icon(self, icon, size=gtk.ICON_SIZE_BUTTON):
		img, x = self.__get_children()
		if type(icon) == str:
			if icon == '':
				img.props.visible = False
			else:
				img.set_from_icon_name(icon, size)
				img.props.visible = True
		else:
			img.set_from_pixbuf(icon)
			img.props.visible = True



class Clock(gtk.Label):
	name = "Clock"

	def __init__(self):
		super(gtk.Label, self).__init__()
		self._format = '%H:%M:%S'
		self._running = False
		self._draining = False
		self._update()

	@property
	def is_running(self):
		return self._running

	def _next_update_interval_ms(self):
		now = time.time()
		nextsecond = 1 - (now - int(now))
		return int(nextsecond * 1000)

	def update_display(self):
		face = time.strftime(self._format, time.localtime(time.time()))
		self.set_markup("<span size='32000'><b>" + face + "</b></span>")

	def _update(self):
		if not self._draining:
			self.update_display()
			glib.timeout_add(self._next_update_interval_ms(), self._update, priority=glib.PRIORITY_DEFAULT_IDLE)
		return False

	def drain(self):
		self._draining = True


class SpinLabel(gtk.EventBox):
	__gsignals__ = {
		'value-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_NONE, ()),
		'user-changed-value': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_NONE, ()),
	}
	def __init__(self, start_value):
		self.format = '%d'
		self._value = start_value
		self._locked = False
		self.range = (0, 59)
		self.label = gtk.Label()
		super(self.__class__, self).__init__()
		self.add(self.label)
		self.connect('scroll-event', self._event_scroll)
		self.connect('motion-notify-event', self._event_drag)
		self.motion_last_pos = 0
		self.drag_sensitivity = 30
		self.show_all()
		self._update_label()
	def __str__(self):
		return str(self._value)
	def __int__(self):
		return self._value
	@property
	def value(self):
		return self._value
	@value.setter
	def value(self, x):
		x = int(x)
		if self.range[1] is not None and x > self.range[1]: x = self.range[0]
		if self.range[0] is not None and x < self.range[0]: x = self.range[1]
		self._value = x
		self._update_label()
		self.emit('value-changed')
	def lock(self):
		self._locked = True
	def unlock(self):
		self._locked = False
	def _event_scroll(self, X, event):
		if self._locked: return
		delta = +1 if event.direction == gtk.gdk.SCROLL_UP else -1
		self.value += delta
		self.emit('user-changed-value')
	def _event_drag(self, X, event):
		if self._locked: return
		diff = event.y - self.motion_last_pos
		if abs(diff) > self.drag_sensitivity:
			delta = +1 if diff < 0 else -1
			self.motion_last_pos = event.y
			self.value += delta
			self.emit('user-changed-value')
	def _update_label(self):
		self.label.set_markup(self.format % self._value)


class AdjustableClock(gtk.HBox):
	__gsignals__ = {
		'user-changed': (gobject.SIGNAL_RUN_LAST, gobject.TYPE_BOOLEAN, ()),
	}

	def __init__(self):
		self.face_component_format = "<span size='32000'%s><b>%%s</b></span>"
		self.span_attr = ''
		self._negative = False
		self.negative_label = gtk.Label()
		self.hours = SpinLabel(0)
		self.minutes = SpinLabel(0)
		self.seconds = SpinLabel(0)
		self.format_labels('%d:', '%02d:', '%02d')
		self.format_negative_label()
		super(gtk.HBox, self).__init__()
		self.pack_start(self.negative_label, expand=False, fill=False)
		for comp in self.hours, self.minutes, self.seconds:
			comp.connect('user-changed-value', lambda *X: self.emit('user-changed'))
			self.pack_start(comp, expand=False, fill=False)

	def format_labels(self, fmt_h, fmt_m, fmt_s, **pango_attrs):
		self.span_attr = ''.join([" %s='%s'" % (attr.replace('_', '-'), val) for attr, val in pango_attrs.iteritems()])
		fmt = self.face_component_format % (self.span_attr,)
		if fmt_h is not None: self.fmt_h = fmt_h
		if fmt_m is not None: self.fmt_m = fmt_m
		if fmt_s is not None: self.fmt_s = fmt_s
		self.format_negative_label()
		self.hours.format = fmt % self.fmt_h
		self.minutes.format = fmt % self.fmt_m
		self.seconds.format = fmt % self.fmt_s
		self.hours.value = self.hours.value
		self.minutes.value = self.minutes.value
		self.seconds.value = self.seconds.value
	def format_negative_label(self):
		fmt = self.face_component_format % (self.span_attr,)
		self.negative_label.set_markup(fmt % ('-' if self._negative else ''))
	@property
	def components(self):
		return int(self.hours), int(self.minutes), int(self.seconds)
	def get_seconds(self):
		return (-1 if self._negative else 1) * (int(self.hours)*3600 + int(self.minutes)*60 + int(self.seconds))
	def lock(self):
		for comp in self.hours, self.minutes, self.seconds:
			comp.lock()
	def unlock(self):
		for comp in self.hours, self.minutes, self.seconds:
			comp.unlock()
	def set(self, h, m, s):
		self.hours.value = h
		self.minutes.value = m
		self.seconds.value = s
	def set_seconds(self, s):
		self._negative = s < 0
		self.format_negative_label()
		s = abs(s)
		self.hours.value = s / 3600
		self.minutes.value = s / 60 % 60
		self.seconds.value = s % 60


